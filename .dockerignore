# Build artifacts
**/bin/
**/obj/
**/out/
**/publish/
**/TestResults/

# IDE
.vs/
.vscode/
.idea/
*.user
*.suo

# Git / CI
.git/
.gitignore
.gitattributes
.github/

# Tooling / scratch
.claude/
.fleet/

# Mobile project (MAUI workloads aren't in the .NET SDK image; not needed in Web service)
DhlLogistics.Mobile/

# Local-only reference material
CBM_Project_Reference/
Client Reference/
*.png
requirement detail and error details.txt

# Secrets — never bake into the image. ECS pulls them from Secrets Manager.
**/secrets.json
**/firebase-adminsdk*.json
**/*.pfx
**/*.pem
**/*.key
**/appsettings.Development.json
**/appsettings.Local.json

# Docs / readme — not needed in image
README.md
*.md
docs/

# Docker itself (avoid recursive copy)
Dockerfile
.dockerignore

# Terraform state + plans — never copy into image
infra/
*.tfstate*
*.tfvars
.terraform/

# Render config (legacy, kept for transition only)
render.yaml
