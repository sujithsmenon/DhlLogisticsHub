{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=DhlLogisticsHub;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "EmailSettings": {
    "ImapHost": "imap.gmail.com",
    "ImapPort": 993,
    "Username": "your-dhl-email@gmail.com",
    "Password": "your-app-password",
    "PollIntervalMinutes": 5
  },
  "Aws": {
    "BucketName": "dhl-logistics-pdfs",
    "Region": "ap-south-1"
  },
  "Syncfusion": {
    "LicenseKey": "YOUR_KEY"
  },
  "Jwt": {
    "Key": "CHANGE-THIS-TO-A-32-CHAR-SECRET-KEY!!",
    "Issuer": "DhlLogisticsHub",
    "Audience": "DhlLogisticsApp"
  },
  "WebPush": {
    "Subject": "mailto:admin@dhllogistics.com",
    "PublicKey":  "GENERATE_WITH: dotnet run --project Tools/VapidGen",
    "PrivateKey": "GENERATE_WITH: dotnet run --project Tools/VapidGen"
  },
  "Firebase": {
    "CredentialFile": "firebase-adminsdk.json"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
