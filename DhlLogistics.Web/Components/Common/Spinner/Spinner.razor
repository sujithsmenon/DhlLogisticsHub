@namespace DhlLogistics.Web.Components.Common.Spinner
@using Syncfusion.Blazor.Spinner
@inject SpinnerService _spinnerService

@if (IsVisible)
{
    <div class="loading-overlay">
        <div class="loading-container">
            <SfSpinner Type="SpinnerType.Bootstrap5" Label="Please Wait.." Size="60"></SfSpinner>
        </div>
    </div>
}

<style>
    .loading-container {
        z-index: 5000;
        width: 100vw;
        height: 100vh;
    }

    .loading-overlay {
        position: fixed;
        top: 0;
        left: 0;
        background: rgba(0,0,0,0.8);
        z-index: 4000;
        width: 100%;
        height: 100%;
    }
</style>

@code
{
    protected bool IsVisible { get; set; }

    protected override void OnInitialized()
    {
        _spinnerService.OnShow += ShowLoadingSpinner;
        _spinnerService.OnHide += HideLoadingSpinner;
    }

    public void ShowLoadingSpinner()
    {
        IsVisible = true;
        if (IsVisible)
            InvokeAsync(StateHasChanged);
    }

    public async void HideLoadingSpinner()
    {
        IsVisible = false;
        await Task.Delay(500);
        if (!IsVisible)
            await InvokeAsync(StateHasChanged);
    }
}
