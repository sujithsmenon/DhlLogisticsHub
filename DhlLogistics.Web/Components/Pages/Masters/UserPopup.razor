@inject LogisticsService Service
@inject IToastService ToastService

<div class="modal-dialog modal-lg modal-dialog-centerd modal-dialog-scrollable modal-top-margin e-small">
    <div class="modal-contentnew">

        <div class="modal-header">
            <h5 class="modal-title">@Title</h5>
            <button type="button" class="btn-close e-small" @onclick="Close" aria-label="Close"></button>
        </div>

        <div class="modal-body">
            <div class="card">
                <div class="card-body">
                    <EditForm Model="@user">
                        <DataAnnotationsValidator />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-Custom-label">Full Name:</label>
                                <SfTextBox @bind-Value="@user.FullName" CssClass="e-small" />
                                <ValidationMessage For="@(() => user.FullName)" />
                            </div>
                            @if (isNew)
                            {
                                <div class="col-md-6 mb-3">
                                    <label class="form-Custom-label">Email:</label>
                                    <SfTextBox @bind-Value="@userEmail" Type="InputType.Email"
                                               CssClass="e-small" Placeholder="user@example.com" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-Custom-label">Password:</label>
                                    <SfTextBox @bind-Value="@password" Type="InputType.Password"
                                               CssClass="e-small" Placeholder="Min 8 chars, include digit" />
                                </div>
                            }
                            <div class="col-md-6 mb-3">
                                <label class="form-Custom-label">Role:</label>
                                <SfComboBox @bind-Value="@user.Role"
                                            TItem="string" TValue="string"
                                            DataSource="@RoleOptions"
                                            CssClass="e-small" ShowClearButton="false" />
                            </div>
                            @if (!isNew)
                            {
                                <div class="col-md-6 mb-3">
                                    <label class="form-Custom-label">Active:</label>
                                    <SfCheckBox @bind-Checked="@user.IsActive" Label="Active" />
                                </div>
                            }
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

        <div class="modal-footer">
            <SfButton OnClick="@Save" CssClass="e-small" IconCss="e-icons e-save" IsPrimary="true">
                @(isNew ? "Save" : "Update")
            </SfButton>
            <SfButton OnClick="@Close" CssClass="e-small" IconCss="e-icons e-circle-close">Cancel</SfButton>
        </div>

    </div>
</div>

@code {
    [CascadingParameter] private IModalDialogContext? Modal { get; set; }

    [Parameter] public EventCallback LoadOnSaveReference { get; set; }
    [Parameter] public string Id { get; set; } = string.Empty;
    [Parameter] public string? Title { get; set; }

    private AppUser user = new() { Role = "Viewer", IsActive = true };
    private string userEmail = "";
    private string password  = "";
    private bool isNew = true;

    private readonly List<string> RoleOptions = new()
    { "Admin", "Manager", "Executive", "Viewer" };

    protected override async Task OnInitializedAsync()
    {
        isNew = string.IsNullOrEmpty(Id);

        if (!isNew)
        {
            var all = await Service.GetAllUsersAsync();
            var existing = all.FirstOrDefault(u => u.Id == Id);
            if (existing is not null)
            {
                user = new AppUser
                {
                    Id       = existing.Id,
                    FullName = existing.FullName,
                    Email    = existing.Email ?? "",
                    Role     = existing.Role,
                    IsActive = existing.IsActive,
                };
            }
        }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(user.FullName))
        {
            ToastService.Show(new() { Title = "Validation", Content = "Full Name is required.", CssClass = "e-toast-danger" });
            return;
        }

        if (isNew)
        {
            if (string.IsNullOrWhiteSpace(userEmail))
            {
                ToastService.Show(new() { Title = "Validation", Content = "Email is required.", CssClass = "e-toast-danger" });
                return;
            }
            if (string.IsNullOrWhiteSpace(password))
            {
                ToastService.Show(new() { Title = "Validation", Content = "Password is required.", CssClass = "e-toast-danger" });
                return;
            }
            user.Email = userEmail;
            var (ok, err) = await Service.AddUserAsync(user, password);
            if (!ok)
            {
                ToastService.Show(new() { Title = "Error!", Content = err, CssClass = "e-toast-danger" });
                return;
            }
        }
        else
        {
            var (ok, err) = await Service.UpdateUserAsync(user);
            if (!ok)
            {
                ToastService.Show(new() { Title = "Error!", Content = err, CssClass = "e-toast-danger" });
                return;
            }
        }

        ToastService.Show(new() { Title = "Success!", Content = "Record Saved Successfully.", CssClass = "e-toast-success" });

        if (LoadOnSaveReference.HasDelegate) await LoadOnSaveReference.InvokeAsync();
        this.Modal?.Close(ModalResult.OK());
    }

    private void Close() => this.Modal?.Close(ModalResult.Cancel());
}
