@inject StaffService Service
@inject StaffDepartmentService DepartmentService
@inject StaffDesignationService DesignationService
@inject IToastService ToastService

<div class="modal-dialog modal-lg modal-dialog-centerd modal-dialog-scrollable modal-top-margin e-small">
    <div class="modal-contentnew">
        <div class="modal-header"><h5 class="modal-title">@Title</h5><button type="button" class="btn-close e-small" @onclick="Close"></button></div>
        <div class="modal-body"><div class="card"><div class="card-body">
            <EditForm Model="@item"><DataAnnotationsValidator />
                <div class="row">
                    <div class="col-md-6 mb-3"><label class="form-Custom-label">Full Name:</label><SfTextBox @bind-Value="@item.FullName" CssClass="e-small" /></div>
                    <div class="col-md-6 mb-3"><label class="form-Custom-label">Email:</label><SfTextBox @bind-Value="@item.Email" CssClass="e-small" /></div>
                    <div class="col-md-4 mb-3"><label class="form-Custom-label">Phone:</label><SfTextBox @bind-Value="@item.Phone" CssClass="e-small" /></div>
                    <div class="col-md-4 mb-3"><label class="form-Custom-label">Department:</label>
                        <SfComboBox @bind-Value="@item.DepartmentId" TItem="StaffDepartment" TValue="int?" DataSource="@departments" CssClass="e-small" AllowFiltering="true" ShowClearButton="true">
                            <ComboBoxFieldSettings Text="DepartmentName" Value="Id" />
                        </SfComboBox>
                    </div>
                    <div class="col-md-4 mb-3"><label class="form-Custom-label">Designation:</label>
                        <SfComboBox @bind-Value="@item.DesignationId" TItem="StaffDesignation" TValue="int?" DataSource="@designations" CssClass="e-small" AllowFiltering="true" ShowClearButton="true">
                            <ComboBoxFieldSettings Text="DesignationName" Value="Id" />
                        </SfComboBox>
                    </div>
                    <div class="col-md-4 mb-3"><label class="form-Custom-label">Date of Joining:</label><SfDatePicker TValue="DateTime?" @bind-Value="@item.DateOfJoining" CssClass="e-small" Format="dd/MMM/yyyy" /></div>
                    <div class="col-md-3 mb-3"><label class="form-Custom-label">Active:</label><SfCheckBox @bind-Checked="@item.IsActive" Label="Active" /></div>
                </div>
            </EditForm>
        </div></div></div>
        <div class="modal-footer">
            <SfButton OnClick="@Save" CssClass="e-small" IconCss="e-icons e-save" IsPrimary="true">@(Id == 0 ? "Save" : "Update")</SfButton>
            <SfButton OnClick="@Close" CssClass="e-small" IconCss="e-icons e-circle-close">Cancel</SfButton>
        </div>
    </div>
</div>

@code {
    [CascadingParameter] private IModalDialogContext? Modal { get; set; }
    [Parameter] public EventCallback LoadOnSaveReference { get; set; }
    [Parameter] public int Id { get; set; }
    [Parameter] public string? Title { get; set; }
    private Staff item = new() { IsActive = true };
    private List<StaffDepartment> departments = new();
    private List<StaffDesignation> designations = new();

    protected override async Task OnInitializedAsync()
    {
        departments  = await DepartmentService.GetAllAsync();
        designations = await DesignationService.GetAllAsync();
        if (Id != 0) { var e = await Service.GetByIdAsync(Id); if (e is not null) item = e; }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(item.FullName)) { ToastService.Show(new() { Title = "Validation", Content = "Full Name is required.", CssClass = "e-toast-danger" }); return; }
        try
        {
            if (Id == 0) await Service.AddAsync(item); else await Service.UpdateAsync(item);
            ToastService.Show(new() { Title = "Success!", Content = "Record Saved Successfully.", CssClass = "e-toast-success" });
            if (LoadOnSaveReference.HasDelegate) await LoadOnSaveReference.InvokeAsync();
            this.Modal?.Close(ModalResult.OK());
        }
        catch (Exception ex) { ToastService.Show(new() { Title = "Error!", Content = ex.Message, CssClass = "e-toast-danger" }); }
    }
    private void Close() => this.Modal?.Close(ModalResult.Cancel());
}
