@page "/masters/branches"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject CompanyBranchService Service
@inject SfDialogService DialogService
@inject IToastService ToastService
<div class="main-div">
    <SfSpinner @bind-Visible="@loader" Label="Loading Data...."></SfSpinner>
    <div class="row"><div class="col-md-12"><div class="card">
        <div class="card-header"><b>Branch List</b></div>
        <div class="card-body">
            <SfGrid ID="Grid" TValue="CompanyBranch" @ref="Grid" DataSource="@model"
                    AllowPaging="true" AllowReordering="true" CssClass="e-small"
                    AllowResizing="true" AllowSelection="true" AllowExcelExport="true"
                    AllowSorting="true" Toolbar="@Toolbaritems" Height="100%" RowHeight="25" Width="100%">
                <GridPageSettings PageSize="15" PageSizes="@pagerDropdown"></GridPageSettings>
                <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.FilterBar"></GridFilterSettings>
                <GridEvents OnToolbarClick="ToolbarClick" CommandClicked="OnCommandClicked" TValue="CompanyBranch"></GridEvents>
                <GridColumns>
                    <GridColumn HeaderText="Manage" Width="80" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" AutoFit="true" AllowReordering="false" AllowResizing="false">
                        <GridCommandColumns>
                            <GridCommandColumn Type="CommandButtonType.Edit" ButtonOption="@(new CommandButtonOptions() { IconCss = "e-icons e-edit", CssClass = "e-flat" })" />
                            <GridCommandColumn Type="CommandButtonType.Delete" ButtonOption="@(new CommandButtonOptions() { IconCss = "e-icons e-delete", CssClass = "e-flat delete-btn" })" />
                        </GridCommandColumns>
                    </GridColumn>
                    <GridColumn Field="@nameof(CompanyBranch.Id)" HeaderText="Id" IsPrimaryKey="true" Visible="false" />
                    <GridColumn Field="@nameof(CompanyBranch.BranchCode)" HeaderText="Code" Width="100" />
                    <GridColumn Field="@nameof(CompanyBranch.BranchName)" HeaderText="Branch Name" Width="240" />
                    <GridColumn Field="@nameof(CompanyBranch.City)"       HeaderText="City"        Width="160" />
                    <GridColumn Field="@nameof(CompanyBranch.Address)"    HeaderText="Address"     Width="280" />
                    <GridColumn Field="@nameof(CompanyBranch.IsActive)"   HeaderText="Active"      Width="80" DisplayAsCheckBox="true" />
                </GridColumns>
            </SfGrid>
        </div>
    </div></div></div>
</div>

<BsModalDialog @ref="_modal" />
<ToastComponent />

@code {
    private BsModalDialog? _modal;
    public List<CompanyBranch> model { get; set; } = new();
    SfGrid<CompanyBranch>? Grid;
    private List<object> Toolbaritems = new() { new ItemModel { Text = "Add New Branch", TooltipText = "Add New Branch", PrefixIcon = "e-add", Id = "AddNew" }, "Search" };
    private bool loader = false;
    public string[] pagerDropdown { get; set; } = new[] { "All", "5", "10", "15", "20" };
    public EventCallback LoadOnSaveReference { get; set; }

    protected override async Task OnInitializedAsync() { LoadOnSaveReference = EventCallback.Factory.Create(this, LoadOnSave); await LoadData(); }
    private async Task LoadData() { try { loader = true; model = await Service.GetAllAsync(); } finally { loader = false; StateHasChanged(); } }
    private async Task LoadOnSave() { await LoadData(); if (Grid is not null) await Grid.Refresh(); }

    public async void ToolbarClick(Syncfusion.Blazor.Navigations.ClickEventArgs args)
    {
        if (args.Item.Text == "Add New Branch")
        {
            var o = new BsModalOptions();
            o.ControlParameters.Add("Id", 0); o.ControlParameters.Add("Title", "New Branch"); o.ControlParameters.Add("LoadOnSaveReference", LoadOnSaveReference);
            var r = await _modal!.Context.ShowAsync<CompanyBranchPopup>(o);
            if (r.ResultType == ModalResultType.OK) await LoadOnSave();
        }
    }

    public async Task OnCommandClicked(CommandClickEventArgs<CompanyBranch> args)
    {
        try
        {
            if (args.CommandColumn.Type == CommandButtonType.Edit)
            {
                var o = new BsModalOptions();
                o.ControlParameters.Add("Id", args.RowData.Id); o.ControlParameters.Add("Title", "Update Branch - " + args.RowData.BranchName); o.ControlParameters.Add("LoadOnSaveReference", LoadOnSaveReference);
                var r = await _modal!.Context.ShowAsync<CompanyBranchPopup>(o);
                if (r.ResultType == ModalResultType.OK) await LoadOnSave();
            }
            else if (args.CommandColumn.Type == CommandButtonType.Delete)
            {
                if (await DialogService.ConfirmAsync("Are you sure you want to delete record?", "Confirm delete"))
                {
                    await Service.DeleteAsync(args.RowData.Id);
                    ToastService.Show(new() { Title = "Success!", Content = "Record Deleted Successfully.", CssClass = "e-toast-success" });
                    await LoadOnSave();
                }
            }
        }
        catch (Exception ex) { ToastService.Show(new() { Title = "Error!", Content = ex.Message, CssClass = "e-toast-danger" }); }
    }
}
