@inject VehicleDocumentService Service
@inject LogisticsService VehicleSvc
@inject VehicleDocumentTypeService DocTypeService
@inject IToastService ToastService

<div class="modal-dialog modal-lg modal-dialog-centerd modal-dialog-scrollable modal-top-margin e-small">
    <div class="modal-contentnew">
        <div class="modal-header"><h5 class="modal-title">@Title</h5><button type="button" class="btn-close e-small" @onclick="Close"></button></div>
        <div class="modal-body"><div class="card"><div class="card-body">
            <EditForm Model="@item"><DataAnnotationsValidator />
                <div class="row">
                    <div class="col-md-4 mb-3"><label class="form-Custom-label">Vehicle:</label>
                        <SfComboBox @bind-Value="@item.VehicleId" TItem="Vehicle" TValue="int" DataSource="@vehicles" CssClass="e-small" AllowFiltering="true" ShowClearButton="false">
                            <ComboBoxFieldSettings Text="PlateNumber" Value="Id" />
                        </SfComboBox>
                    </div>
                    <div class="col-md-4 mb-3"><label class="form-Custom-label">Document Type:</label>
                        <SfComboBox @bind-Value="@item.VehicleDocumentTypeId" TItem="VehicleDocumentType" TValue="int" DataSource="@docTypes" CssClass="e-small" AllowFiltering="true" ShowClearButton="false">
                            <ComboBoxFieldSettings Text="DocumentTypeName" Value="Id" />
                        </SfComboBox>
                    </div>
                    <div class="col-md-4 mb-3"><label class="form-Custom-label">Document No.:</label><SfTextBox @bind-Value="@item.DocumentNumber" CssClass="e-small" /></div>
                    <div class="col-md-3 mb-3"><label class="form-Custom-label">Issue Date:</label><SfDatePicker TValue="DateTime?" @bind-Value="@item.IssueDate" CssClass="e-small" Format="dd/MMM/yyyy" /></div>
                    <div class="col-md-3 mb-3"><label class="form-Custom-label">Expiry Date:</label><SfDatePicker TValue="DateTime?" @bind-Value="@item.ExpiryDate" CssClass="e-small" Format="dd/MMM/yyyy" /></div>
                    <div class="col-md-6 mb-3"><label class="form-Custom-label">Remarks:</label><SfTextBox @bind-Value="@item.Remarks" CssClass="e-small" /></div>
                </div>
            </EditForm>
        </div></div></div>
        <div class="modal-footer">
            <SfButton OnClick="@Save" CssClass="e-small" IconCss="e-icons e-save" IsPrimary="true">@(Id == 0 ? "Save" : "Update")</SfButton>
            <SfButton OnClick="@Close" CssClass="e-small" IconCss="e-icons e-circle-close">Cancel</SfButton>
        </div>
    </div>
</div>

@code {
    [CascadingParameter] private IModalDialogContext? Modal { get; set; }
    [Parameter] public EventCallback LoadOnSaveReference { get; set; }
    [Parameter] public int Id { get; set; }
    [Parameter] public string? Title { get; set; }
    private VehicleDocument item = new();
    private List<Vehicle> vehicles = new();
    private List<VehicleDocumentType> docTypes = new();

    protected override async Task OnInitializedAsync()
    {
        vehicles = await VehicleSvc.GetAllVehiclesAsync();
        docTypes = await DocTypeService.GetAllAsync();
        if (Id != 0) { var e = await Service.GetByIdAsync(Id); if (e is not null) item = e; }
    }

    private async Task Save()
    {
        if (item.VehicleId == 0) { ToastService.Show(new() { Title = "Validation", Content = "Vehicle is required.", CssClass = "e-toast-danger" }); return; }
        if (item.VehicleDocumentTypeId == 0) { ToastService.Show(new() { Title = "Validation", Content = "Document Type is required.", CssClass = "e-toast-danger" }); return; }
        try
        {
            if (Id == 0) await Service.AddAsync(item); else await Service.UpdateAsync(item);
            ToastService.Show(new() { Title = "Success!", Content = "Record Saved Successfully.", CssClass = "e-toast-success" });
            if (LoadOnSaveReference.HasDelegate) await LoadOnSaveReference.InvokeAsync();
            this.Modal?.Close(ModalResult.OK());
        }
        catch (Exception ex) { ToastService.Show(new() { Title = "Error!", Content = ex.Message, CssClass = "e-toast-danger" }); }
    }
    private void Close() => this.Modal?.Close(ModalResult.Cancel());
}
