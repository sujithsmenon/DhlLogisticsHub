<div class="main-div">
    <SfSpinner @bind-Visible="@loader" Label="Loading Data...."></SfSpinner>
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <b>Client List</b>
                </div>
                <div class="card-body">
                    <SfGrid ID="Grid" TValue="DhlClient" @ref="Grid" DataSource="@model"
                            AllowPaging="true" AllowReordering="true" CssClass="e-small"
                            AllowResizing="true" AllowSelection="true" AllowExcelExport="true"
                            AllowSorting="true" Toolbar="@Toolbaritems" Height="100%" RowHeight="25" Width="100%">
                        <GridPageSettings PageSize="15" PageSizes="@pagerDropdown"></GridPageSettings>
                        <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.FilterBar"></GridFilterSettings>
                        <GridEvents OnToolbarClick="ToolbarClick" CommandClicked="OnCommandClicked" TValue="DhlClient"></GridEvents>

                        <GridColumns>
                            <GridColumn HeaderText="Manage" Width="80" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" AutoFit="true" AllowReordering="false" AllowResizing="false">
                                <GridCommandColumns>
                                    <GridCommandColumn Type="CommandButtonType.Edit" ButtonOption="@(new CommandButtonOptions() { IconCss = "e-icons e-edit", CssClass = "e-flat" })"></GridCommandColumn>
                                    <GridCommandColumn Type="CommandButtonType.Delete" ButtonOption="@(new CommandButtonOptions() { IconCss = "e-icons e-delete", CssClass = "e-flat delete-btn" })"></GridCommandColumn>
                                </GridCommandColumns>
                            </GridColumn>

                            <GridColumn Field="@nameof(DhlClient.Id)" HeaderText="Id" IsPrimaryKey="true" Visible="false"></GridColumn>
                            <GridColumn Field="@nameof(DhlClient.CompanyName)" HeaderText="Company Name" Width="240"></GridColumn>
                            <GridColumn Field="@nameof(DhlClient.ContactEmail)" HeaderText="Email" Width="240"></GridColumn>
                            <GridColumn Field="@nameof(DhlClient.Phone)" HeaderText="Phone" Width="160"></GridColumn>
                            <GridColumn Field="@nameof(DhlClient.Address)" HeaderText="Address" Width="280"></GridColumn>
                        </GridColumns>
                    </SfGrid>
                </div>
            </div>
        </div>
    </div>
</div>

<BsModalDialog @ref="_modal" />
<ToastComponent />

@code {
    private BsModalDialog? _modal;
    public static List<DhlClient> model { get; set; } = new();
    SfGrid<DhlClient>? Grid;
    private List<Object> Toolbaritems = new List<Object>() {
        new ItemModel() { Text = "Add New Client", TooltipText = "Add New Client", PrefixIcon = "e-add", Id = "AddNew" }
      , "Search" };
    private bool loader = false;
    public string[] pagerDropdown { get; set; } = new string[] { "All", "5", "10", "15", "20" };
    public EventCallback LoadOnSaveReference { get; set; }
    private bool AllowAccess = true;

    protected override async Task OnInitializedAsync()
    {
        LoadOnSaveReference = EventCallback.Factory.Create(this, LoadOnSave);
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            loader = true;
            model = await Service.GetAllClientsAsync();
        }
        finally
        {
            loader = false;
            StateHasChanged();
        }
    }

    private async Task LoadOnSave()
    {
        await LoadData();
        if (Grid is not null) await Grid.Refresh();
    }

    public async void ToolbarClick(Syncfusion.Blazor.Navigations.ClickEventArgs args)
    {
        if (args.Item.Text != null && args.Item.Text.Equals("Add New Client"))
        {
            var option = new BsModalOptions();
            option.ControlParameters.Add("Id", 0);
            option.ControlParameters.Add("Title", "New Client Details");
            option.ControlParameters.Add("LoadOnSaveReference", LoadOnSaveReference);

            var result = await _modal!.Context.ShowAsync<ClientPopup>(option);
            if (result.ResultType == ModalResultType.OK)
                await LoadOnSave();
        }
    }

    public async Task OnCommandClicked(CommandClickEventArgs<DhlClient> args)
    {
        try
        {
            if (args.CommandColumn.Type == CommandButtonType.Edit)
            {
                var option = new BsModalOptions();
                option.ControlParameters.Add("Id", args.RowData.Id);
                option.ControlParameters.Add("Title", "Update Client Details - " + args.RowData.CompanyName);
                option.ControlParameters.Add("LoadOnSaveReference", LoadOnSaveReference);

                var result = await _modal!.Context.ShowAsync<ClientPopup>(option);
                if (result.ResultType == ModalResultType.OK)
                    await LoadOnSave();
            }
            else if (args.CommandColumn.Type == CommandButtonType.Delete)
            {
                bool confirmed = await DialogService.ConfirmAsync("Are you sure you want to delete record?", "Confirm delete");
                if (confirmed)
                {
                    await Service.DeleteClientAsync(args.RowData.Id);
                    ToastService.Show(new() { Title = "Success!", Content = "Record Deleted Successfully.", CssClass = "e-toast-success" });
                    await LoadOnSave();
                }
            }
        }
        catch (Exception ex)
        {
            ToastService.Show(new() { Title = "Error!", Content = ex.Message, CssClass = "e-toast-danger" });
        }
    }
}
