@page "/masters/containers"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject LogisticsService Service
@inject SfDialogService DialogService
@inject IToastService ToastService
@inject PermissionService PermService
@inject NavigationManager Nav

<HeadContent>
    <link rel="stylesheet" href="default.css" />
</HeadContent>

@if (!AllowAccess)
{
    <p>Checking permissions...</p>
    return;
}

<style>
    .centered-content {
        display: flex;
        align-items: center;
    }

    .e-btn.e-icon-btn, .e-css.e-btn.e-icon-btn {
        padding: 0px 3px !important;
    }

    .e-grid .e-rowcell {
        border-style: solid;
        border-width: 1px 0 0;
        font-size: 12px;
        overflow: hidden;
        padding: 2px 2px;
        vertical-align: middle;
        white-space: nowrap;
        width: auto;
    }

    .e-grid .e-headercelldiv {
        border: 0 none;
        display: block;
        font-size: 12px;
        font-weight: 700;
        height: 18px;
        line-height: 18px;
    }

    .e-grid .e-emptyrow td {
        line-height: 12px;
        padding: .7em;
        font-size: smaller;
    }

    .e-grid .e-altrow {
        background-color: #c6eefd66;
    }
</style>

<div class="main-div">
    <SfSpinner @bind-Visible="@loader" Label="Loading Data...."></SfSpinner>
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <b>Container List</b>
                </div>
                <div class="card-body">
                    <SfGrid ID="Grid" TValue="Container" @ref="Grid" DataSource="@model"
                            AllowPaging="true" AllowReordering="true" CssClass="e-small"
                            AllowResizing="true" AllowSelection="true" AllowExcelExport="true"
                            AllowSorting="true" Toolbar="@Toolbaritems" Height="100%" RowHeight="25" Width="100%">
                        <GridPageSettings PageSize="15" PageSizes="@pagerDropdown"></GridPageSettings>
                        <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.FilterBar"></GridFilterSettings>
                        <GridEvents OnToolbarClick="ToolbarClick" CommandClicked="OnCommandClicked" TValue="Container"></GridEvents>

                        <GridColumns>
                            <GridColumn HeaderText="Manage" Width="80" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" AutoFit="true" AllowReordering="false" AllowResizing="false">
                                <GridCommandColumns>
                                    <GridCommandColumn Type="CommandButtonType.Edit" ButtonOption="@(new CommandButtonOptions() { IconCss = "e-icons e-edit", CssClass = "e-flat" })"></GridCommandColumn>
                                    <GridCommandColumn Type="CommandButtonType.Delete" ButtonOption="@(new CommandButtonOptions() { IconCss = "e-icons e-delete", CssClass = "e-flat delete-btn" })"></GridCommandColumn>
                                </GridCommandColumns>
                            </GridColumn>

                            <GridColumn HeaderText="Status" Width="130" TextAlign="TextAlign.Center">
                                <Template>
                                    @{
                                        var row = context as Container;

                                        if (row?.Status == ContainerStatus.Available)
                                        {
                                            <div class="statustemp e-approvedcolor">
                                                <span class="statustxt e-approvedcolor">Available</span>
                                            </div>
                                        }
                                        else if (row?.Status == ContainerStatus.InUse)
                                        {
                                            <div class="statustemp e-pendingcolor">
                                                <span class="statustxt e-activecolor">In Use</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="statustemp e-disablecolor">
                                                <span class="statustxt e-disablecolor">Maintenance</span>
                                            </div>
                                        }
                                    }
                                </Template>
                            </GridColumn>

                            <GridColumn Field="@nameof(Container.Id)" HeaderText="Id" IsPrimaryKey="true" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Right" Width="120" Visible="false"></GridColumn>
                            <GridColumn Field="@nameof(Container.ContainerNumber)" HeaderText="Container No." Width="220"></GridColumn>
                            <GridColumn Field="@nameof(Container.ContainerType)" HeaderText="Type" Width="160"></GridColumn>
                        </GridColumns>
                    </SfGrid>
                </div>
            </div>
        </div>
    </div>
</div>

<BsModalDialog @ref="_modal" />
<ToastComponent />

@code {
    private BsModalDialog? _modal;
    public static List<Container> model { get; set; } = new();
    SfGrid<Container>? Grid;
    private List<Object> Toolbaritems = new List<Object>() {
        new ItemModel() { Text = "Add New Container", TooltipText = "Add New Container", PrefixIcon = "e-add", Id = "AddNew" }
      , "Search" };
    private bool loader = false;
    public string[] pagerDropdown { get; set; } = new string[] { "All", "5", "10", "15", "20" };
    public EventCallback LoadOnSaveReference { get; set; }
    private bool AllowAccess = false;
    private bool CanCreate, CanEdit, CanDelete;
    private const string PagePath = "masters/containers";

    [CascadingParameter] private Task<Microsoft.AspNetCore.Components.Authorization.AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var auth = AuthStateTask is null ? null : await AuthStateTask;
        var user = auth?.User;

        if (!await PermService.CheckPermissionAsync(user, PagePath, Permission.View))
        {
            Nav.NavigateTo($"/no-permission/{PagePath.Replace("/", "%2F")}/Access denied.", true);
            return;
        }
        AllowAccess = true;
        CanCreate = await PermService.CheckPermissionAsync(user, PagePath, Permission.Create);
        CanEdit   = await PermService.CheckPermissionAsync(user, PagePath, Permission.Edit);
        CanDelete = await PermService.CheckPermissionAsync(user, PagePath, Permission.Delete);

        LoadOnSaveReference = EventCallback.Factory.Create(this, LoadOnSave);
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            loader = true;
            model = await Service.GetContainersAsync();
        }
        finally
        {
            loader = false;
            StateHasChanged();
        }
    }

    private async Task LoadOnSave()
    {
        await LoadData();
        if (Grid is not null) await Grid.Refresh();
    }

    public async void ToolbarClick(Syncfusion.Blazor.Navigations.ClickEventArgs args)
    {
        if (args.Item.Text != null && args.Item.Text.Equals("Add New Container"))
        {
            if (!CanCreate)
            {
                ToastService.Show(new() { Title = "Permission denied", Content = "You don't have permission to create.", CssClass = "e-toast-danger" });
                return;
            }
            var option = new BsModalOptions();
            option.ControlParameters.Add("Id", 0);
            option.ControlParameters.Add("Title", "New Container Details");
            option.ControlParameters.Add("LoadOnSaveReference", LoadOnSaveReference);

            var result = await _modal!.Context.ShowAsync<ContainerPopup>(option);
            if (result.ResultType == ModalResultType.OK)
                await LoadOnSave();
        }
    }

    public async Task OnCommandClicked(CommandClickEventArgs<Container> args)
    {
        try
        {
            if (args.CommandColumn.Type == CommandButtonType.Edit)
            {
                if (!CanEdit)
                {
                    ToastService.Show(new() { Title = "Permission denied", Content = "You don't have permission to edit.", CssClass = "e-toast-danger" });
                    return;
                }
                var option = new BsModalOptions();
                option.ControlParameters.Add("Id", args.RowData.Id);
                option.ControlParameters.Add("Title", "Update Container Details - " + args.RowData.ContainerNumber);
                option.ControlParameters.Add("LoadOnSaveReference", LoadOnSaveReference);

                var result = await _modal!.Context.ShowAsync<ContainerPopup>(option);
                if (result.ResultType == ModalResultType.OK)
                    await LoadOnSave();
            }
            else if (args.CommandColumn.Type == CommandButtonType.Delete)
            {
                if (!CanDelete)
                {
                    ToastService.Show(new() { Title = "Permission denied", Content = "You don't have permission to delete.", CssClass = "e-toast-danger" });
                    return;
                }
                bool confirmed = await DialogService.ConfirmAsync("Are you sure you want to delete record?", "Confirm delete");
                if (confirmed)
                {
                    await Service.DeleteContainerAsync(args.RowData.Id);
                    ToastService.Show(new()
                    {
                        Title = "Success!",
                        Content = "Record Deleted Successfully.",
                        CssClass = "e-toast-success"
                    });
                    await LoadOnSave();
                }
            }
        }
        catch (Exception ex)
        {
            ToastService.Show(new()
            {
                Title = "Error!",
                Content = ex.Message,
                CssClass = "e-toast-danger"
            });
        }
    }
}
