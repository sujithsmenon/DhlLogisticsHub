@inject AwbShipmentService Service
@inject IToastService ToastService

<div class="modal-dialog modal-lg modal-dialog-centerd modal-dialog-scrollable modal-top-margin e-small">
    <div class="modal-contentnew">

        <div class="modal-header">
            <h5 class="modal-title">@Title</h5>
            <button type="button" class="btn-close e-small" @onclick="Close" aria-label="Close"></button>
        </div>

        <div class="modal-body">
            <div class="card">
                <div class="card-body">
                    <EditForm Model="@transporter">
                        <DataAnnotationsValidator />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-Custom-label">Company Name:</label>
                                <SfTextBox @bind-Value="@transporter.CompanyName" CssClass="e-small" />
                                <ValidationMessage For="@(() => transporter.CompanyName)" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-Custom-label">Contact Person:</label>
                                <SfTextBox @bind-Value="@transporter.ContactPerson" CssClass="e-small" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-Custom-label">Phone:</label>
                                <SfTextBox @bind-Value="@transporter.Phone" CssClass="e-small" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-Custom-label">WhatsApp:</label>
                                <SfTextBox @bind-Value="@transporter.WhatsAppNumber" CssClass="e-small" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-Custom-label">Email:</label>
                                <SfTextBox @bind-Value="@transporter.Email" CssClass="e-small" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-Custom-label">Address:</label>
                                <SfTextBox @bind-Value="@transporter.Address" CssClass="e-small" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-Custom-label">Active:</label>
                                <SfCheckBox @bind-Checked="@transporter.IsActive" Label="Active" />
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

        <div class="modal-footer">
            <SfButton OnClick="@Save" CssClass="e-small" IconCss="e-icons e-save" IsPrimary="true">
                @(Id == 0 ? "Save" : "Update")
            </SfButton>
            <SfButton OnClick="@Close" CssClass="e-small" IconCss="e-icons e-circle-close">Cancel</SfButton>
        </div>

    </div>
</div>

@code {
    [CascadingParameter] private IModalDialogContext? Modal { get; set; }

    [Parameter] public EventCallback LoadOnSaveReference { get; set; }
    [Parameter] public int Id { get; set; }
    [Parameter] public string? Title { get; set; }

    private Transporter transporter = new() { IsActive = true };

    protected override async Task OnInitializedAsync()
    {
        if (Id != 0)
        {
            var all = await Service.GetAllTransportersAsync();
            var existing = all.FirstOrDefault(t => t.Id == Id);
            if (existing is not null)
            {
                transporter = new Transporter
                {
                    Id             = existing.Id,
                    CompanyName    = existing.CompanyName,
                    ContactPerson  = existing.ContactPerson,
                    Phone          = existing.Phone,
                    WhatsAppNumber = existing.WhatsAppNumber,
                    Email          = existing.Email,
                    Address        = existing.Address,
                    IsActive       = existing.IsActive,
                };
            }
        }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(transporter.CompanyName))
        {
            ToastService.Show(new() { Title = "Validation", Content = "Company Name is required.", CssClass = "e-toast-danger" });
            return;
        }

        try
        {
            if (Id == 0) await Service.AddTransporterAsync(transporter);
            else                    await Service.UpdateTransporterAsync(transporter);

            ToastService.Show(new() { Title = "Success!", Content = "Record Saved Successfully.", CssClass = "e-toast-success" });

            if (LoadOnSaveReference.HasDelegate) await LoadOnSaveReference.InvokeAsync();
            this.Modal?.Close(ModalResult.OK());
        }
        catch (Exception ex)
        {
            ToastService.Show(new() { Title = "Error!", Content = ex.Message, CssClass = "e-toast-danger" });
        }
    }

    private void Close() => this.Modal?.Close(ModalResult.Cancel());
}
