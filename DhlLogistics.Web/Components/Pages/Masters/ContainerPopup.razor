@inject LogisticsService Service
@inject IToastService ToastService

<div class="modal-dialog modal-lg modal-dialog-centerd modal-dialog-scrollable modal-top-margin e-small">
    <div class="modal-contentnew">

        <div class="modal-header">
            <h5 class="modal-title">@Title</h5>
            <button type="button" class="btn-close e-small" @onclick="Close" aria-label="Close"></button>
        </div>

        <div class="modal-body">
            <div class="card">
                <div class="card-body">
                    <EditForm Model="@container">
                        <DataAnnotationsValidator />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-Custom-label">Container Number:</label>
                                <SfTextBox @bind-Value="@container.ContainerNumber"
                                           CssClass="e-small" Placeholder="ABCD1234567" />
                                <ValidationMessage For="@(() => container.ContainerNumber)" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-Custom-label">Container Type:</label>
                                <SfComboBox @bind-Value="@container.ContainerType"
                                            TItem="string" TValue="string"
                                            DataSource="@TypeOptions"
                                            CssClass="e-small" AllowFiltering="true"
                                            ShowClearButton="false" />
                                <ValidationMessage For="@(() => container.ContainerType)" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-Custom-label">Status:</label>
                                <SfComboBox @bind-Value="@container.Status"
                                            TItem="ContainerStatus" TValue="ContainerStatus"
                                            DataSource="@StatusOptions"
                                            CssClass="e-small" ShowClearButton="false" />
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

        <div class="modal-footer">
            <SfButton OnClick="@Save" CssClass="e-small" IconCss="e-icons e-save" IsPrimary="true">
                @(Id == 0 ? "Save" : "Update")
            </SfButton>
            <SfButton OnClick="@Close" CssClass="e-small" IconCss="e-icons e-circle-close">Cancel</SfButton>
        </div>

    </div>
</div>

@code {
    [CascadingParameter] private IModalDialogContext? Modal { get; set; }

    [Parameter] public EventCallback LoadOnSaveReference { get; set; }
    [Parameter] public int Id { get; set; }
    [Parameter] public string? Title { get; set; }

    private Container container = new() { Status = ContainerStatus.Available };

    private readonly List<string> TypeOptions = new()
    { "20ft", "40ft", "40ft HC", "Reefer", "Open Top", "Flat Rack" };

    private readonly List<ContainerStatus> StatusOptions =
        Enum.GetValues<ContainerStatus>().ToList();

    protected override async Task OnInitializedAsync()
    {
        if (Id != 0)
        {
            var all = await Service.GetContainersAsync();
            var existing = all.FirstOrDefault(c => c.Id == Id);
            if (existing is not null)
            {
                container = new Container
                {
                    Id              = existing.Id,
                    ContainerNumber = existing.ContainerNumber,
                    ContainerType   = existing.ContainerType,
                    Status          = existing.Status,
                };
            }
        }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(container.ContainerNumber))
        {
            ToastService.Show(new()
            {
                Title = "Validation",
                Content = "Container Number is required.",
                CssClass = "e-toast-danger"
            });
            return;
        }
        if (string.IsNullOrWhiteSpace(container.ContainerType))
        {
            ToastService.Show(new()
            {
                Title = "Validation",
                Content = "Container Type is required.",
                CssClass = "e-toast-danger"
            });
            return;
        }

        try
        {
            if (Id == 0)
                await Service.AddContainerAsync(container);
            else
                await Service.UpdateContainerAsync(container);

            ToastService.Show(new()
            {
                Title = "Success!",
                Content = "Record Saved Successfully.",
                CssClass = "e-toast-success"
            });

            if (LoadOnSaveReference.HasDelegate)
                await LoadOnSaveReference.InvokeAsync();

            this.Modal?.Close(ModalResult.OK());
        }
        catch (Exception ex)
        {
            ToastService.Show(new()
            {
                Title = "Error!",
                Content = ex.Message,
                CssClass = "e-toast-danger"
            });
        }
    }

    private void Close() => this.Modal?.Close(ModalResult.Cancel());
}
