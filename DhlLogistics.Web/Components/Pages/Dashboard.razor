@page "/"
@inject LogisticsService Svc
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject DashboardState Dash
@implements IAsyncDisposable

<!-- Leaflet -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="js/dhlmap.js"></script>

@if (_loading)
{
    <div class="loading-wrap">Loading dashboard…</div>
}
else
{
    <!-- KPI row (clickable → drill-down with filter) -->
    <div class="kpi-grid">
        <div class="kpi-card red" role="button" tabindex="0" style="cursor:pointer"
             @onclick='() => Nav.NavigateTo("/jobs?status=Pending")'>
            <div class="kpi-icon">🚛</div>
            <div class="kpi-body">
                <div class="kpi-value">@_data!.TotalPendingPickups</div>
                <div class="kpi-label">Pending Pickups</div>
            </div>
        </div>
        <div class="kpi-card blue" role="button" tabindex="0" style="cursor:pointer"
             @onclick='() => Nav.NavigateTo("/jobs?status=InTransit")'>
            <div class="kpi-icon">📍</div>
            <div class="kpi-body">
                <div class="kpi-value">@_data!.TotalInTransit</div>
                <div class="kpi-label">In Transit</div>
            </div>
        </div>
        <div class="kpi-card green" role="button" tabindex="0" style="cursor:pointer"
             @onclick='() => Nav.NavigateTo("/jobs?status=Stored")'>
            <div class="kpi-icon">✅</div>
            <div class="kpi-body">
                <div class="kpi-value">@_data.TotalShippedThisMonth</div>
                <div class="kpi-label">Stored This Month</div>
            </div>
        </div>
        <div class="kpi-card orange" role="button" tabindex="0" style="cursor:pointer"
             @onclick='() => Nav.NavigateTo("/masters/containers")'>
            <div class="kpi-icon">📦</div>
            <div class="kpi-body">
                <div class="kpi-value">@_data.TotalActiveContainers</div>
                <div class="kpi-label">Active Containers</div>
            </div>
        </div>
        <div class="kpi-card purple" role="button" tabindex="0" style="cursor:pointer"
             @onclick='() => Nav.NavigateTo("/staff")'>
            <div class="kpi-icon">👤</div>
            <div class="kpi-body">
                <div class="kpi-value">@_data!.TotalActiveExecutives</div>
                <div class="kpi-label">Active Executives</div>
            </div>
        </div>
        <div class="kpi-card yellow" role="button" tabindex="0" style="cursor:pointer"
             @onclick='() => Nav.NavigateTo("/masters/clients")'>
            <div class="kpi-icon">🏢</div>
            <div class="kpi-body">
                <div class="kpi-value">@_data.TotalActiveClients</div>
                <div class="kpi-label">DHL Clients</div>
            </div>
        </div>
    </div>

    <!-- Map + Activity feed -->
    <div class="two-col mb20">
        <div class="card">
            <div class="card-head">
                🗺 Live Executive Tracking
                <span class="live-badge @(_hubConnected ? "live" : "offline")">
                    <span class="live-dot"></span>
                    @(_hubConnected ? "Live" : "Offline")
                </span>
            </div>
            <div id="dhl-map" style="height:340px;width:100%;"></div>
        </div>

        <div class="card">
            <div class="card-head">⚡ Recent Activity</div>
            <div class="scroll-y" style="max-height:340px;">
                @if (!_recentJobs.Any())
                {
                    <div class="empty-state">No recent activity</div>
                }
                else
                {
                    <div class="timeline">
                        @foreach (var job in _recentJobs)
                        {
                            <div class="timeline-item">
                                <div class="timeline-dot @TimelineDotColor(job.Status)"></div>
                                <div>
                                    <div class="timeline-text">
                                        <span class="bold">@job.JobCode</span> — @job.ClientName
                                    </div>
                                    <div class="timeline-time">
                                        @job.Status &nbsp;·&nbsp; @job.CreatedAt.ToString("dd MMM HH:mm")
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Active jobs table -->
    <div class="card mb20">
        <div class="card-head">
            📋 Active Jobs
            <a href="/jobs" style="font-size:12px;font-weight:500;color:var(--red);text-decoration:none;">View all →</a>
        </div>
        <div class="scroll-y" style="max-height:280px;">
            @foreach (var job in _activeJobs)
            {
                <div class="data-row @(job.JobId == _selectedJob ? "selected" : "")"
                     @onclick="() => SelectJob(job)">
                    <div class="mono" style="width:120px;color:var(--red);font-size:11px;">@job.JobCode</div>
                    <div style="flex:1;font-weight:600;">@job.ExecutiveName</div>
                    <div style="flex:2;color:var(--muted);font-size:12px;">@job.PickupAddress</div>
                    <div style="width:110px;">
                        <span class="pill @StatusPill(job.Status)">
                            <span class="dot"></span>@job.Status
                        </span>
                    </div>
                    @if (job.LastLat != 0)
                    {
                        <div style="width:150px;font-family:var(--mono);font-size:10px;color:var(--muted);">
                            @job.LastLat.ToString("F4"), @job.LastLng.ToString("F4")
                        </div>
                    }
                </div>
            }
            @if (!_activeJobs.Any())
            {
                <div class="empty-state">No active jobs</div>
            }
        </div>
    </div>

    <!-- GPS feed -->
    @if (_gpsLog.Any())
    {
        <div class="card">
            <div class="card-head">📡 GPS Feed</div>
            <div class="scroll-y" style="max-height:160px;">
                @foreach (var e in _gpsLog.TakeLast(10).Reverse())
                {
                    <div class="gps-log-row">
                        <span class="ts">@e.Time.ToString("HH:mm:ss")</span>
                        <span>@e.JobCode</span>
                        <span>@e.Lat.ToString("F5"), @e.Lng.ToString("F5")</span>
                        <span>@e.Speed.ToString("F1") km/h</span>
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    private DailyReportData?  _data;
    private List<PickupJob>   _recentJobs  = [];
    private List<JobRow>      _activeJobs  = [];
    private List<GpsEntry>    _gpsLog      = [];
    private Dictionary<string,bool> _markers = [];
    private HubConnection?    _hub;
    private bool  _loading      = true;
    private bool  _hubConnected = false;
    private string? _selectedJob;

    protected override async Task OnInitializedAsync()
    {
        await LoadCountersAsync();
        // Live counters: any CRUD / status change anywhere raises DashboardState.Changed,
        // which reloads the figures without a page refresh.
        Dash.Changed += OnDashboardChanged;
        _loading = false;
    }

    // Loads the KPI figures + recent/active job lists. Reused on first load and on
    // every live-refresh signal.
    private async Task LoadCountersAsync()
    {
        // All six KPI figures now come straight from the DB via Svc.get() (real counts,
        // no page-local derivation). _recentJobs still feeds the activity feed + table.
        _data       = await Svc.get();
        _recentJobs = await Svc.GetRecentJobsAsync(12);

        _activeJobs = _recentJobs
            .Where(j => j.Status != JobStatus.Stored && j.Status != JobStatus.Cancelled)
            .Select(j => new JobRow
            {
                JobId         = j.Id.ToString(),
                JobCode       = j.JobCode,
                ExecutiveName = j.AssignedExecutiveId ?? "Unassigned",
                PickupAddress = j.PickupAddress,
                Status        = j.Status.ToString(),
            }).ToList();
    }

    // DashboardState.Changed fires on a non-UI thread — marshal back via InvokeAsync.
    private async void OnDashboardChanged()
    {
        try
        {
            await InvokeAsync(async () =>
            {
                await LoadCountersAsync();
                StateHasChanged();
            });
        }
        catch { /* component disposed mid-refresh — ignore */ }
    }

    private bool _mapInitialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_loading || _mapInitialized) return;
        _mapInitialized = true;

        await JS.InvokeVoidAsync("DhlMap.init", "dhl-map", 10.8505, 76.2711, 7);

        // Seed demo markers
        foreach (var job in _activeJobs.Where(j => j.LastLat != 0))
            await AddOrUpdateMarkerAsync(job.JobId, job.LastLat, job.LastLng, job.ExecutiveName, job.Status, 0);

        await ConnectHubAsync();
    }

    private async Task ConnectHubAsync()
    {
        _hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/gpshub"))
            .WithAutomaticReconnect()
            .Build();

        _hub.On<string, double, double, double, DateTime>("LocationUpdated",
            async (jobId, lat, lng, speed, time) =>
            {
                var job = _activeJobs.FirstOrDefault(j => j.JobId == jobId);
                if (job is not null) { job.LastLat = lat; job.LastLng = lng; }

                await AddOrUpdateMarkerAsync(jobId, lat, lng, job?.ExecutiveName ?? jobId, job?.Status ?? "InTransit", speed);

                _gpsLog.Add(new GpsEntry { Time = time, JobCode = job?.JobCode ?? jobId, Lat = lat, Lng = lng, Speed = speed });
                if (_gpsLog.Count > 50) _gpsLog.RemoveAt(0);

                if (_selectedJob == jobId) await JS.InvokeVoidAsync("DhlMap.panTo", lat, lng);
                await InvokeAsync(StateHasChanged);
            });

        _hub.Reconnected += async _ => { _hubConnected = true;  await InvokeAsync(StateHasChanged); };
        _hub.Closed      += async _ => { _hubConnected = false; await InvokeAsync(StateHasChanged); };

        try { await _hub.StartAsync(); await _hub.SendAsync("WatchJob", "all"); _hubConnected = true; StateHasChanged(); }
        catch { _hubConnected = false; }
    }

    private async Task AddOrUpdateMarkerAsync(string jobId, double lat, double lng, string label, string status, double speed)
    {
        var popup = $"<b>{label}</b><br/>{status}<br/>{speed:F1} km/h";
        if (_markers.ContainsKey(jobId))
            await JS.InvokeVoidAsync("DhlMap.moveMarker", jobId, lat, lng, popup);
        else { await JS.InvokeVoidAsync("DhlMap.addMarker", jobId, lat, lng, popup); _markers[jobId] = true; }
    }

    private async Task SelectJob(JobRow job)
    {
        _selectedJob = job.JobId;
        if (job.LastLat != 0) await JS.InvokeVoidAsync("DhlMap.panTo", job.LastLat, job.LastLng);
    }

    public async ValueTask DisposeAsync()
    {
        Dash.Changed -= OnDashboardChanged;
        if (_hub is not null) await _hub.DisposeAsync();
    }

    private static string StatusPill(string s) => s switch
    {
        "InTransit" => "pill-transit",
        "Assigned"  => "pill-assigned",
        "PickedUp"  => "pill-pickedup",
        "Stored"    => "pill-stored",
        "Cancelled" => "pill-cancelled",
        _           => "pill-pending",
    };
    private static string TimelineDotColor(JobStatus s) => s switch
    {
        JobStatus.InTransit => "blue",
        JobStatus.PickedUp  => "green",
        JobStatus.Stored    => "green",
        _                   => "",
    };

    private class JobRow
    {
        public string JobId        { get; set; } = "";
        public string JobCode      { get; set; } = "";
        public string ExecutiveName{ get; set; } = "";
        public string PickupAddress{ get; set; } = "";
        public string Status       { get; set; } = "";
        public double LastLat      { get; set; }
        public double LastLng      { get; set; }
    }
    private class GpsEntry
    {
        public DateTime Time  { get; set; }
        public string JobCode { get; set; } = "";
        public double Lat     { get; set; }
        public double Lng     { get; set; }
        public double Speed   { get; set; }
    }
}
