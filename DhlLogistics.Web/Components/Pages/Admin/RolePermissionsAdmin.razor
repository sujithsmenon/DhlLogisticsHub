@page "/admin/permissions"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject PermissionService PermService
@inject AppDbContext Db
@inject RoleManager<IdentityRole> RoleManager
@inject IToastService ToastService
@inject NavigationManager Nav
@using DhlLogistics.Web.Database
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]

<div class="main-div">
    <div class="row"><div class="col-md-12"><div class="card">
        <div class="card-header"><b>Role × Page Permissions</b></div>
        <div class="card-body">

            <div class="row" style="padding:8px 4px;">
                <div class="mb-3 col-md-3">
                    <label class="form-Custom-label">Role:</label>
                    <SfDropDownList @bind-Value="selectedRole" TItem="string" TValue="string"
                                    DataSource="@roles" Placeholder="Select role"
                                    CssClass="e-small" ShowClearButton="false">
                        <DropDownListEvents TItem="string" TValue="string" ValueChange="@OnRoleChanged" />
                    </SfDropDownList>
                </div>
                <div class="mb-3 col-md-3" style="display:flex;align-items:flex-end;gap:6px;">
                    <SfButton OnClick="@SaveAllAsync" CssClass="e-small" IconCss="e-icons e-save" IsPrimary="true" Disabled="@(string.IsNullOrEmpty(selectedRole))">
                        Save All
                    </SfButton>
                    <SfButton OnClick="@SelectAllAsync" CssClass="e-small" IconCss="e-icons e-check" Disabled="@(string.IsNullOrEmpty(selectedRole))">
                        Grant All
                    </SfButton>
                    <SfButton OnClick="@ClearAllAsync" CssClass="e-small" IconCss="e-icons e-circle-close" Disabled="@(string.IsNullOrEmpty(selectedRole))">
                        Revoke All
                    </SfButton>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(selectedRole))
            {
                <div style="overflow-x:auto;">
                    <table class="e-table" style="width:100%;font-size:12px;border-collapse:collapse;">
                        <thead>
                            <tr style="background:#0868B2;color:#fff;">
                                <th style="padding:6px 10px;text-align:left;">Page</th>
                                @foreach (var p in AllPermissions)
                                {
                                    <th style="padding:6px 10px;text-align:center;width:80px;">@p</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @{ int idx = 0; }
                            @foreach (var page in Pages)
                            {
                                var rowBg = (idx++ % 2 == 0) ? "transparent" : "#c6eefd66";
                                <tr style="background:@rowBg;">
                                    <td style="padding:4px 10px;">
                                        <div style="font-weight:600;">@(page.Label)</div>
                                        <div class="muted" style="font-size:10px;">@(page.Path)</div>
                                    </td>
                                    @foreach (var perm in AllPermissions)
                                    {
                                        var key = $"{page.Path}|{perm}";
                                        var granted = matrix.TryGetValue(key, out var v) && v;
                                        <td style="padding:4px;text-align:center;">
                                            <SfCheckBox @bind-Checked="@matrix[key]" />
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="muted" style="padding:24px;text-align:center;">Select a role to edit permissions.</div>
            }

        </div>
    </div></div></div>
</div>

<ToastComponent />

@code {
    private string? selectedRole;
    private List<string> roles = new();
    private Dictionary<string, bool> matrix = new();

    record PageEntry(string Path, string Label);

    private static readonly Permission[] AllPermissions = new[]
    {
        Permission.View, Permission.Create, Permission.Edit, Permission.Delete,
        Permission.Approve, Permission.Verify, Permission.Export, Permission.Print,
    };

    // The list of pages permissioned in the app. Add new pages here as they
    // get permission gating.
    private static readonly List<PageEntry> Pages = new()
    {
        // CBM-parity stubs
        new("masters/branches",            "Branches"),
        new("masters/shipment-activities", "Shipment Activities"),
        // M1 masters
        new("masters/containers",          "Containers"),
        new("masters/vehicles",            "Vehicles"),
        new("masters/transporters",        "Transporters"),
        new("masters/users",               "Users"),
        new("masters/clients",             "Clients"),
        // M2 geography
        new("masters/countries",           "Countries"),
        new("masters/regions",             "Regions"),
        new("masters/states",              "States"),
        new("masters/ports",               "Ports"),
        new("masters/sez-locations",       "SEZ Locations"),
        // M2 finance
        new("masters/currencies",          "Currencies"),
        new("masters/sac",                 "SAC Codes"),
        new("masters/charge-codes",        "Charge Codes"),
        // M2 catalogues
        new("masters/container-sizes",     "Container Sizes"),
        new("masters/commodities",         "Commodities"),
        new("masters/vessels",             "Vessels"),
        // M2 fleet
        new("masters/vehicle-drivers",     "Vehicle Drivers"),
        new("masters/vehicle-document-types", "Vehicle Doc Types"),
        new("masters/vehicle-documents",   "Vehicle Documents"),
        new("masters/driver-document-types", "Driver Doc Types"),
        // M2 HR
        new("masters/staff-departments",   "Staff Departments"),
        new("masters/staff-designations",  "Staff Designations"),
        new("masters/staff",               "Staff"),
        // Operations
        new("awb",                         "AWB Shipments"),
        new("export",                      "Export Jobs"),
        new("jobs",                        "Pickup Jobs"),
        new("jobs/clearance",              "Clearance Jobs"),
        new("jobs/forwarding",             "Forwarding Jobs"),
        new("jobs/verify",                 "Job Verification"),
        new("jobs/approve",                "Job Approval"),
        new("tracking",                    "Live Tracking"),
        new("cargo",                       "Cargo & Containers"),
        new("admin/permissions",           "Role Permissions (Admin)"),
    };

    protected override async Task OnInitializedAsync()
    {
        roles = (await RoleManager.Roles.OrderBy(r => r.Name).ToListAsync())
                .Select(r => r.Name!).ToList();
    }

    private async Task OnRoleChanged(Syncfusion.Blazor.DropDowns.ChangeEventArgs<string, string> args)
    {
        selectedRole = args.Value;
        await LoadMatrixAsync();
    }

    private async Task LoadMatrixAsync()
    {
        matrix.Clear();
        if (string.IsNullOrEmpty(selectedRole)) return;

        var existing = await Db.RolePagePermissions
            .Where(p => p.RoleId == selectedRole)
            .ToListAsync();

        foreach (var page in Pages)
            foreach (var perm in AllPermissions)
            {
                var key = $"{page.Path}|{perm}";
                var row = existing.FirstOrDefault(p => p.PagePath == page.Path && p.Permission == perm);
                matrix[key] = row?.IsGranted ?? false;
            }
    }

    private async Task SaveAllAsync()
    {
        if (string.IsNullOrEmpty(selectedRole)) return;
        try
        {
            foreach (var page in Pages)
                foreach (var perm in AllPermissions)
                {
                    var key = $"{page.Path}|{perm}";
                    var granted = matrix.TryGetValue(key, out var v) && v;
                    await PermService.SetPermissionAsync(selectedRole, page.Path, perm, granted);
                }
            ToastService.Show(new() { Title = "Saved", Content = $"Permissions saved for role '{selectedRole}'.", CssClass = "e-toast-success" });
        }
        catch (Exception ex)
        {
            ToastService.Show(new() { Title = "Error", Content = ex.Message, CssClass = "e-toast-danger" });
        }
    }

    private async Task SelectAllAsync()
    {
        foreach (var page in Pages)
            foreach (var perm in AllPermissions)
                matrix[$"{page.Path}|{perm}"] = true;
        await Task.CompletedTask;
    }

    private async Task ClearAllAsync()
    {
        foreach (var page in Pages)
            foreach (var perm in AllPermissions)
                matrix[$"{page.Path}|{perm}"] = false;
        await Task.CompletedTask;
    }
}
