@page "/jobs/verify"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject JobOrderService Service
@inject SfDialogService DialogService
@inject IToastService ToastService
<div class="main-div">
    <SfSpinner @bind-Visible="@loader" Label="Loading Data...."></SfSpinner>
    <div class="row"><div class="col-md-12"><div class="card">
        <div class="card-header d-flex align-items-center">
            <span><b>Job Verification Queue</b></span>
            <div class="ms-auto d-flex gap-2 align-items-center">
                <label class="form-Custom-label mb-0">Mode:</label>
                <SfDropDownList @bind-Value="modeFilter" TItem="ModeOption" TValue="string"
                                DataSource="@_modes" Width="160px" CssClass="e-small">
                    <DropDownListFieldSettings Text="Label" Value="Value" />
                    <DropDownListEvents TItem="ModeOption" TValue="string" ValueChange="@OnModeChanged" />
                </SfDropDownList>
                <SfButton OnClick="@LoadData" CssClass="e-small" IconCss="e-icons e-refresh" IsPrimary="true">Refresh</SfButton>
            </div>
        </div>
        <div class="card-body">
            <SfGrid ID="Grid" TValue="JobOrder" @ref="Grid" DataSource="@filtered"
                    AllowPaging="true" AllowReordering="true" CssClass="e-small"
                    AllowResizing="true" AllowSelection="true"
                    AllowSorting="true" Toolbar="@(new List<string>{ "Search" })" Height="100%" RowHeight="25" Width="100%">
                <GridPageSettings PageSize="15" PageSizes="@pagerDropdown"></GridPageSettings>
                <GridEvents CommandClicked="OnCommandClicked" TValue="JobOrder" />
                <GridColumns>
                    <GridColumn HeaderText="Action" Width="160" TextAlign="TextAlign.Center" AllowReordering="false" AllowResizing="false">
                        <GridCommandColumns>
                            <GridCommandColumn Type="CommandButtonType.None" ButtonOption="@(new() { Content = "Verify", IconCss = "e-icons e-check",        CssClass = "e-flat e-primary" })" />
                            <GridCommandColumn Type="CommandButtonType.None" ButtonOption="@(new() { Content = "Reject", IconCss = "e-icons e-circle-close", CssClass = "e-flat delete-btn" })" />
                        </GridCommandColumns>
                    </GridColumn>
                    <GridColumn Field="@nameof(JobOrder.Id)" HeaderText="Id" IsPrimaryKey="true" Visible="false" />
                    <GridColumn Field="@nameof(JobOrder.JobOrderNo)"   HeaderText="Job No"      Width="140" />
                    <GridColumn Field="@nameof(JobOrder.Mode)"         HeaderText="Mode"        Width="100" />
                    <GridColumn Field="@nameof(JobOrder.JobOrderDate)" HeaderText="Date"        Width="100" Format="dd-MMM-yyyy" />
                    <GridColumn Field="BillingClient.CompanyName"      HeaderText="Client"      Width="220" />
                    <GridColumn Field="Shipper.CompanyName"            HeaderText="Shipper"     Width="180" />
                    <GridColumn Field="Consignee.CompanyName"          HeaderText="Consignee"   Width="180" />
                    <GridColumn Field="LoadPort.PortName"              HeaderText="Load Port"   Width="120" />
                    <GridColumn Field="DischargePort.PortName"         HeaderText="Disch Port"  Width="120" />
                    <GridColumn Field="Commodity.CommodityName"        HeaderText="Commodity"   Width="120" />
                    <GridColumn Field="@nameof(JobOrder.SubmittedBy)"  HeaderText="Submitted By" Width="120" />
                    <GridColumn Field="@nameof(JobOrder.SubmittedOn)"  HeaderText="Submitted On" Width="140" Format="dd-MMM-yyyy HH:mm" />
                </GridColumns>
            </SfGrid>
        </div>
    </div></div></div>
</div>

<SfDialog @ref="_rejectDlg" Width="420px" Height="auto" IsModal="true" ShowCloseIcon="true" Visible="false">
    <DialogTemplates>
        <Header>Reject Job @(_selected?.JobOrderNo)</Header>
        <Content>
            <div class="mb-2">
                <label class="form-Custom-label">Reason:</label>
                <SfTextBox Multiline="true" @bind-Value="@_rejectReason" CssClass="e-small" />
            </div>
        </Content>
    </DialogTemplates>
    <DialogButtons>
        <DialogButton Content="Reject" IsPrimary="true" OnClick="@ConfirmReject" />
        <DialogButton Content="Cancel" OnClick="@CancelReject" />
    </DialogButtons>
</SfDialog>

<ToastComponent />

@code {
    public record ModeOption(string Value, string Label);

    private SfGrid<JobOrder>? Grid;
    private bool loader = false;
    public string[] pagerDropdown { get; set; } = new[] { "All", "10", "15", "20" };

    private List<JobOrder> model = new();
    private List<JobOrder> filtered = new();
    private string modeFilter = "ALL";

    private static readonly List<ModeOption> _modes = new()
    {
        new("ALL",        "All"),
        new("CLEARANCE",  "Clearance"),
        new("FORWARDING", "Forwarding"),
    };

    private SfDialog? _rejectDlg;
    private JobOrder? _selected;
    private string _rejectReason = string.Empty;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        try
        {
            loader = true;
            model = await Service.GetByStatusAsync(JobOrderStatus.Submitted);
            ApplyFilter();
        }
        finally { loader = false; StateHasChanged(); }
    }

    private void ApplyFilter()
    {
        filtered = modeFilter switch
        {
            "CLEARANCE"  => model.Where(j => j.Mode == JobMode.Clearance).ToList(),
            "FORWARDING" => model.Where(j => j.Mode == JobMode.Forwarding).ToList(),
            _            => model.ToList(),
        };
    }

    private void OnModeChanged(Syncfusion.Blazor.DropDowns.ChangeEventArgs<string, ModeOption> args)
    {
        modeFilter = args.Value;
        ApplyFilter();
    }

    public async Task OnCommandClicked(CommandClickEventArgs<JobOrder> args)
    {
        var label = args.CommandColumn?.ButtonOption?.Content;
        try
        {
            if (label == "Verify")
            {
                await Service.VerifyAsync(args.RowData.Id);
                ToastService.Show(new() { Title = "Verified", Content = $"Job {args.RowData.JobOrderNo} verified.", CssClass = "e-toast-success" });
                await LoadData();
            }
            else if (label == "Reject")
            {
                _selected = args.RowData;
                _rejectReason = string.Empty;
                if (_rejectDlg is not null) await _rejectDlg.ShowAsync();
            }
        }
        catch (Exception ex)
        {
            ToastService.Show(new() { Title = "Error!", Content = ex.Message, CssClass = "e-toast-danger" });
        }
    }

    private async Task ConfirmReject()
    {
        if (_selected is null) return;
        if (string.IsNullOrWhiteSpace(_rejectReason))
        {
            ToastService.Show(new() { Title = "Validation", Content = "Rejection reason is required.", CssClass = "e-toast-danger" });
            return;
        }
        try
        {
            await Service.RejectAsync(_selected.Id, _rejectReason);
            ToastService.Show(new() { Title = "Rejected", Content = $"Job {_selected.JobOrderNo} rejected.", CssClass = "e-toast-success" });
            if (_rejectDlg is not null) await _rejectDlg.HideAsync();
            await LoadData();
        }
        catch (Exception ex)
        {
            ToastService.Show(new() { Title = "Error!", Content = ex.Message, CssClass = "e-toast-danger" });
        }
    }

    private async Task CancelReject()
    {
        if (_rejectDlg is not null) await _rejectDlg.HideAsync();
    }
}
