@page "/users"
@inject LogisticsService Svc

<div class="page-hdr">
    <div>
        <h1>User Activity</h1>
        <div class="sub">@_users.Count user(s) registered</div>
    </div>
</div>

@if (_loading)
{
    <div class="loading-wrap">Loading users…</div>
}
else if (!_users.Any())
{
    <div class="empty-state">No users found</div>
}
else
{
    <div class="equal-col" style="align-items:start;">

        <!-- User list -->
        <div class="card">
            <div class="card-head">Users</div>
            <div class="scroll-y" style="max-height:calc(100vh - 220px);">
                @foreach (var u in _users)
                {
                    <div class="data-row @(_selected?.UserId == u.UserId ? "selected" : "")"
                         @onclick="() => _selected = u">
                        <div class="avatar" style="margin-right:12px;flex-shrink:0;">
                            @Initials(u.FullName)
                        </div>
                        <div style="flex:1;">
                            <div style="font-weight:600;font-size:13px;">@u.FullName</div>
                            <div style="font-size:11px;color:var(--muted);">@u.Email</div>
                        </div>
                        <div style="text-align:right;">
                            <span class="pill @RolePill(u.Role)" style="margin-bottom:4px;display:inline-block;">@u.Role</span>
                            <div style="font-size:11px;color:var(--muted);">@u.TotalJobs jobs</div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Detail panel -->
        <div>
            @if (_selected is null)
            {
                <div class="card">
                    <div class="card-body empty-state">Select a user to see activity</div>
                </div>
            }
            else
            {
                <div class="card mb16">
                    <div class="card-head">
                        <div style="display:flex;align-items:center;gap:12px;">
                            <div class="avatar">@Initials(_selected.FullName)</div>
                            <div>
                                <div style="font-weight:700;">@_selected.FullName</div>
                                <div style="font-size:11px;color:var(--muted);">@_selected.Email</div>
                            </div>
                        </div>
                        <span class="pill @(_selected.IsActive ? "pill-active" : "pill-inactive")">
                            @(_selected.IsActive ? "Active" : "Inactive")
                        </span>
                    </div>
                    <div class="card-body">
                        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;text-align:center;">
                            <div>
                                <div style="font-size:24px;font-weight:800;color:var(--text);">@_selected.TotalJobs</div>
                                <div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;">Total</div>
                            </div>
                            <div>
                                <div style="font-size:24px;font-weight:800;color:var(--blue);">@_selected.ActiveJobs</div>
                                <div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;">Active</div>
                            </div>
                            <div>
                                <div style="font-size:24px;font-weight:800;color:var(--green);">@_selected.CompletedJobs</div>
                                <div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;">Done</div>
                            </div>
                        </div>

                        @if (_selected.LastJobAt.HasValue)
                        {
                            <div style="margin-top:16px;padding-top:12px;border-top:1px solid var(--border);font-size:12px;color:var(--muted);">
                                Last active: <span style="color:var(--text);font-weight:600;">@_selected.LastJobAt.Value.ToString("dd MMM yyyy")</span>
                            </div>
                        }

                        <!-- Progress bar -->
                        @if (_selected.TotalJobs > 0)
                        {
                            var pct = (int)Math.Round(_selected.CompletedJobs * 100.0 / _selected.TotalJobs);
                            <div style="margin-top:16px;">
                                <div style="display:flex;justify-content:space-between;font-size:11px;margin-bottom:6px;">
                                    <span class="muted">Completion rate</span>
                                    <span style="font-weight:700;">@pct%</span>
                                </div>
                                <div style="background:var(--border);border-radius:4px;height:6px;overflow:hidden;">
                                    <div style="width:@pct%;background:var(--green);height:100%;border-radius:4px;transition:width .4s;"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="card">
                    <div class="card-head">Role &amp; Access</div>
                    <div class="card-body">
                        <span class="pill @RolePill(_selected.Role)" style="font-size:13px;padding:5px 14px;">@_selected.Role</span>
                        <div style="margin-top:12px;font-size:12px;color:var(--muted);">
                            @RoleDescription(_selected.Role)
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<UserActivityDto> _users    = [];
    private UserActivityDto?      _selected;
    private bool                  _loading  = true;

    protected override async Task OnInitializedAsync()
    {
        _users   = await Svc.GetUserActivitiesAsync();
        _loading = false;
    }

    private static string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}"
            : name.Length > 0 ? name[0].ToString() : "?";
    }

    private static string RolePill(string role) => role switch
    {
        "Admin"     => "pill-admin",
        "Manager"   => "pill-manager",
        "Executive" => "pill-executive",
        _           => "pill-viewer",
    };

    private static string RoleDescription(string role) => role switch
    {
        "Admin"     => "Full system access — can manage users, vehicles, and all jobs.",
        "Manager"   => "Can assign jobs, view all executives, and access reports.",
        "Executive" => "Can update their own assigned jobs and send GPS location.",
        _           => "Read-only access to dashboard data.",
    };
}
