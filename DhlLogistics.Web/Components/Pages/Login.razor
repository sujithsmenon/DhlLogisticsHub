@page "/login"
@layout AuthLayout
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

<PageTitle>Sign In — PVGT Logistics LLP</PageTitle>

<div class="auth-bg">

    <!-- ── Left brand panel ─────────────────────────────────────── -->
    <div class="auth-left">
        <div class="auth-brand">
            <div class="auth-pvgt-mark">
                <img src="img/pvgt-logo.png" alt="PVGT Logistics" class="auth-pvgt-logo" />
            </div>
            <div class="auth-brand-words">
                <span class="auth-brand-name">PVGT Logistics LLP</span>
                <span class="auth-brand-sub">Your Trust &amp; Satisfaction</span>
            </div>
        </div>

        <div class="auth-hero">
            <h1 class="auth-hero-h1">Manage<br />logistics<br />smarter.</h1>
            <p class="auth-hero-p">
                Real-time GPS tracking, automated job parsing, and
                container oversight — all from one secure platform.
            </p>
        </div>

        <div class="auth-feature-list">
            <div class="auth-feature">
                <span class="auth-feature-icon">📦</span>
                <span>Live Container &amp; Cargo Tracking</span>
            </div>
            <div class="auth-feature">
                <span class="auth-feature-icon">🚛</span>
                <span>Fleet &amp; Executive Management</span>
            </div>
            <div class="auth-feature">
                <span class="auth-feature-icon">📧</span>
                <span>Automated Email-to-Job Parsing</span>
            </div>
            <div class="auth-feature">
                <span class="auth-feature-icon">🔔</span>
                <span>Real-time Push Notifications</span>
            </div>
        </div>
    </div>

    <!-- ── Right form panel ─────────────────────────────────────── -->
    <div class="auth-right">
        <div class="auth-card">

            <!-- Card header -->
            <div class="auth-card-head">
                <div class="auth-card-mark">
                    <img src="img/pvgt-logo.png" alt="PVGT Logistics" class="auth-card-logo" />
                </div>
                <h2 class="auth-card-title">Welcome back</h2>
                <p class="auth-card-sub">Sign in to your account to continue</p>
            </div>

            <!-- Error alert -->
            @if (Error is not null)
            {
                <div class="auth-alert" role="alert">
                    <span class="auth-alert-icon">⚠</span>
                    @(Error == "1"
                        ? "Invalid email or password. Please try again."
                        : "Access denied. Contact your administrator.")
                </div>
            }

            <!-- Login form — POSTs to Razor Page handler -->
            <form method="post" action="/Account/Login" class="auth-form" novalidate>
                <AntiforgeryToken />
                <input type="hidden" name="ReturnUrl" value="@(ReturnUrl ?? "/")" />

                <div class="auth-field">
                    <label for="auth-email">Email address</label>
                    <div class="auth-input-wrap @(Error != null ? "input-error" : "")">
                        <span class="auth-icon">✉</span>
                        <input id="auth-email"
                               name="Email"
                               type="email"
                               placeholder="you@pvgtlogistics.com"
                               autocomplete="email"
                               required />
                    </div>
                </div>

                <div class="auth-field">
                    <label for="auth-pw">Password</label>
                    <div class="auth-input-wrap @(Error != null ? "input-error" : "")">
                        <span class="auth-icon">🔒</span>
                        <input id="auth-pw"
                               name="Password"
                               type="password"
                               placeholder="Enter your password"
                               autocomplete="current-password"
                               required />
                    </div>
                </div>

                <div class="auth-opts-row">
                    <label class="auth-check-label">
                        <input type="checkbox" name="RememberMe" value="true" />
                        <span>Remember me for 7 days</span>
                    </label>
                </div>

                <button type="submit" class="auth-submit">
                    Sign In
                    <span class="auth-arrow">→</span>
                </button>
            </form>

            <div class="auth-help">
                <span>Need access?</span>
                <a href="mailto:admin@pvgtlogistics.com">Contact support</a>
            </div>
        </div>

        <p class="auth-copy">&copy; @DateTime.Now.Year PVGT Logistics LLP. Authorized use only.</p>
    </div>
</div>

<style>
/* ── Full-screen split layout ──────────────────────────────────── */
html, body { height: 100%; overflow: hidden; }

.auth-bg {
    display: flex;
    height: 100vh;
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

/* ── Left panel ────────────────────────────────────────────────── */
.auth-left {
    flex: 0 0 42%;
    background: linear-gradient(160deg, #0E2A47 0%, #0868B2 100%); /* PVGT Navy → Blue */
    display: flex;
    flex-direction: column;
    padding: 44px 52px;
    position: relative;
    overflow: hidden;
}

.auth-left::before {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 360px; height: 360px;
    background: radial-gradient(circle, rgba(8,104,178,.18) 0%, transparent 70%);
    pointer-events: none;
}

.auth-left::after {
    content: '';
    position: absolute;
    bottom: -80px; left: -60px;
    width: 280px; height: 280px;
    background: radial-gradient(circle, rgba(8,104,178,.10) 0%, transparent 70%);
    pointer-events: none;
}

/* Brand */
.auth-brand {
    display: flex;
    align-items: center;
    gap: 14px;
}

.auth-pvgt-mark {
    background: #FFFFFF;
    border-radius: 8px;
    padding: 6px 10px;
    display: flex;
    align-items: center;
    justify-content: center;
}
.auth-pvgt-logo {
    display: block;
    height: 32px;
    width: auto;
    max-width: 110px;
}

.auth-brand-words { display: flex; flex-direction: column; }
.auth-brand-name {
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    line-height: 1.3;
}
.auth-brand-sub {
    color: rgba(255,255,255,.38);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: .5px;
}

/* Hero text */
.auth-hero { margin-top: 64px; margin-bottom: 48px; }

.auth-hero-h1 {
    color: #fff;
    font-size: 44px;
    font-weight: 800;
    line-height: 1.12;
    letter-spacing: -.5px;
    margin-bottom: 18px;
}

.auth-hero-p {
    color: rgba(255,255,255,.5);
    font-size: 14px;
    line-height: 1.75;
    max-width: 310px;
}

/* Feature list */
.auth-feature-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: auto;
}

.auth-feature {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    background: rgba(255,255,255,.055);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 10px;
    color: rgba(255,255,255,.72);
    font-size: 13px;
}

.auth-feature-icon {
    font-size: 16px;
    flex-shrink: 0;
    width: 24px;
    text-align: center;
}

/* ── Right panel ───────────────────────────────────────────────── */
.auth-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #F5F6FA;
    padding: 40px 24px;
    overflow-y: auto;
}

/* Form card */
.auth-card {
    background: #fff;
    border-radius: 18px;
    box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 8px 32px rgba(0,0,0,.09);
    padding: 44px 40px;
    width: 100%;
    max-width: 424px;
}

/* Card header */
.auth-card-head { margin-bottom: 30px; }

.auth-card-mark {
    display: flex;
    width: fit-content;
    margin-bottom: 20px;
}
.auth-card-logo {
    display: block;
    height: 36px;
    width: auto;
    max-width: 130px;
}

.auth-card-title {
    font-size: 26px;
    font-weight: 800;
    color: #111827;
    letter-spacing: -.3px;
    margin-bottom: 5px;
}
.auth-card-sub {
    color: #6B7280;
    font-size: 13.5px;
}

/* Alert */
.auth-alert {
    display: flex;
    align-items: center;
    gap: 9px;
    background: #FEF2F2;
    border: 1px solid #FECACA;
    color: #B91C1C;
    border-radius: 10px;
    padding: 11px 14px;
    font-size: 13px;
    margin-bottom: 22px;
    animation: shake .4s ease;
}
.auth-alert-icon { font-size: 15px; flex-shrink: 0; }

/* Form fields */
.auth-form { display: flex; flex-direction: column; gap: 18px; }

.auth-field {
    display: flex;
    flex-direction: column;
    gap: 7px;
}

.auth-field label {
    font-size: 13px;
    font-weight: 600;
    color: #374151;
}

.auth-input-wrap {
    display: flex;
    align-items: center;
    border: 1.5px solid #E5E7EB;
    border-radius: 10px;
    background: #F9FAFB;
    transition: border-color .15s, box-shadow .15s, background .15s;
    overflow: hidden;
}

.auth-input-wrap:focus-within {
    border-color: #0868B2;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(8,104,178,.09);
}

.auth-input-wrap.input-error {
    border-color: #FCA5A5;
    background: #FFF5F5;
}

.auth-icon {
    flex-shrink: 0;
    padding: 0 12px;
    font-size: 14px;
    color: #9CA3AF;
    user-select: none;
}

.auth-input-wrap input {
    flex: 1;
    border: none;
    background: transparent;
    outline: none;
    padding: 12px 14px 12px 0;
    font-size: 14px;
    color: #111827;
}
.auth-input-wrap input::placeholder { color: #9CA3AF; }

/* Options row */
.auth-opts-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.auth-check-label {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    font-size: 13px;
    color: #6B7280;
    user-select: none;
}

.auth-check-label input[type=checkbox] {
    width: 15px;
    height: 15px;
    accent-color: #0868B2;
    cursor: pointer;
    border-radius: 4px;
}

/* Submit button */
.auth-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 14px;
    background: #0868B2;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: .2px;
    transition: background .15s, transform .1s, box-shadow .15s;
    margin-top: 4px;
    box-shadow: 0 4px 14px rgba(8,104,178,.3);
}
.auth-submit:hover {
    background: #055891;
    box-shadow: 0 6px 20px rgba(8,104,178,.4);
}
.auth-submit:active { transform: scale(.985); }

.auth-arrow { font-size: 17px; }

/* Help link */
.auth-help {
    margin-top: 24px;
    text-align: center;
    font-size: 12.5px;
    color: #9CA3AF;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
}
.auth-help a {
    color: #0868B2;
    text-decoration: none;
    font-weight: 600;
}
.auth-help a:hover { text-decoration: underline; }

/* Footer */
.auth-copy {
    margin-top: 28px;
    color: #B0B7C3;
    font-size: 11.5px;
    text-align: center;
}

/* Animations */
@@keyframes shake {
    0%, 100% { transform: translateX(0); }
    20%       { transform: translateX(-6px); }
    40%       { transform: translateX(6px); }
    60%       { transform: translateX(-4px); }
    80%       { transform: translateX(4px); }
}

/* ── Responsive ────────────────────────────────────────────────── */
@@media (max-width: 900px) {
    .auth-left { flex: 0 0 36%; padding: 36px 36px; }
    .auth-hero-h1 { font-size: 34px; }
}

@@media (max-width: 700px) {
    .auth-left { display: none; }
    .auth-right {
        background: #fff;
        padding: 32px 20px;
        justify-content: flex-start;
        padding-top: 48px;
    }
    .auth-card {
        box-shadow: none;
        padding: 0;
        background: transparent;
    }
}
</style>

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] public string? Error     { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated ?? false)
            Nav.NavigateTo(ReturnUrl ?? "/", forceLoad: false);
    }
}
