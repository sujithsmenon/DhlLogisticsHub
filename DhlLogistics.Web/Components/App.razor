<!DOCTYPE html>
<html lang="en">

    <head>
         <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PVGT Logistics LLP</title>
    <base href="/" />

    <!-- No-flicker theme boot: apply the saved theme to <html> BEFORE first paint.
         Runs synchronously while the head parses, so the page never flashes the
         wrong theme on a hard refresh. Must stay inline and before the stylesheets. -->
    <script>
        (function () {
            try {
                var t = localStorage.getItem('dhl-theme') === 'dark' ? 'dark' : 'light';
                var el = document.documentElement;
                el.setAttribute('data-dark', t === 'dark' ? 'true' : 'false');
                el.setAttribute('data-theme', t);
            } catch (e) { /* private mode / storage disabled */ }
        })();
    </script>

    <!-- Bootstrap (required for modal/grid/cards) -->
    <link rel="stylesheet" href="lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Syncfusion theme (bootstrap5 — matches CBM look) -->
    <link href="_content/Syncfusion.Blazor.Themes/bootstrap5.css" rel="stylesheet" />

    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

    <!-- CBM-ported modal / card / toolbar overrides -->
    <link rel="stylesheet" href="default.css" />

    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="DhlLogistics.Web.styles.css" />
    <!-- CBM-style grid overlay (PVGT blue header) -->
    <link rel="stylesheet" href="syncfusion-grid-pvgt.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="InteractiveServer" /> 
  @*  <Routes /> *@
    <Syncfusion.Blazor.Popups.SfDialogProvider />

    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="" class="reload">Reload</a>
        <a class="dismiss">&#10006;</a>
    </div>
	<ReconnectModal />
    <script src="_framework/blazor.web.js"></script>

    <!-- Theme + layout interop (no external libraries) -->
    <script src="js/theme.js"></script>

    <!-- Syncfusion JS -->
    <script src="_content/Syncfusion.Blazor.Core/scripts/syncfusion-blazor.min.js"
            type="text/javascript"></script>

    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <!-- DHL map interop -->
    <script src="js/dhlmap.js"></script>

    <!-- DHL Web Push -->
    <script src="js/dhlpush.js"></script>
</body>

</html>
