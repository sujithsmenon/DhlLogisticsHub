@using Microsoft.EntityFrameworkCore
@using DhlLogistics.Web.Database
@using DhlLogistics.Web.Model
@using DhlLogistics.Web.Service

@inject IDbContextFactory<AppDbContext> MenuFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject PermissionService Perm
@inject NavigationManager Nav
@inject ILogger<NavMenu> Logger
@implements IDisposable

<nav class="sidebar-nav">

    @if (!_loaded)
    {
        <div class="sidebar-section">Loading…</div>
    }
    else
    {
        <div class="sidebar-section">Main</div>

        @foreach (var node in _roots)
        {
            @if (node.IsGroup)
            {
                <details class="nav-group" open="@node.Menu.DefaultOpen">
                    <summary>
                        <span class="nav-icon">@node.Menu.Icon</span> @node.Menu.MenuName
                        <span class="nav-caret">▶</span>
                    </summary>
                    <div class="nav-group-body">
                        @foreach (var child in node.Children)
                        {
                            <div class="nav-item-dhl">
                                @RenderLink(child.Menu)
                            </div>
                        }
                    </div>
                </details>
            }
            else
            {
                <div class="nav-item-dhl">
                    @RenderLink(node.Menu)
                </div>
            }
        }
    }

</nav>

@code {
    private bool _loaded;
    private List<MenuNode> _roots = new();

    /// <summary>A menu row plus its rendered children (one level — the sidebar is flat groups → leaves).</summary>
    private sealed class MenuNode
    {
        public required Menu Menu { get; init; }
        public List<MenuNode> Children { get; } = new();
        public bool IsGroup => string.IsNullOrEmpty(Menu.PageName) && Children.Count > 0;
    }

    protected override async Task OnInitializedAsync()
    {
        // Re-evaluate permissions on every navigation so menu changes (granting/revoking
        // a page's View claim) show up without a full re-login. The sidebar lives in the
        // layout and is otherwise initialised only once per circuit.
        Nav.LocationChanged += OnLocationChanged;
        await ReloadAsync();
        _loaded = true;
    }

    private bool _disposed;
    private bool _reloading;

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) => _ = ReloadAsync();

    private async Task ReloadAsync()
    {
        // Skip overlapping reloads (LocationChanged is fire-and-forget) and any reload
        // after the component is gone, so a navigation never renders into a disposed tree.
        if (_disposed || _reloading) return;
        _reloading = true;
        try
        {
            await LoadMenuAsync();
        }
        catch (Exception ex)
        {
            // A missing / unreachable menu SQL Server must never take down the whole
            // layout — degrade to an empty sidebar and log for diagnosis.
            Logger.LogError(ex, "Failed to load navigation menu from the database.");
        }
        finally
        {
            _reloading = false;
            if (!_disposed) await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        _disposed = true;
        Nav.LocationChanged -= OnLocationChanged;
    }

    private async Task LoadMenuAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated != true) return;

        // Page-paths this user may View. null => Admin (everything visible).
        var viewable = await Perm.GetViewablePagePathsAsync(user);

        await using var db = await MenuFactory.CreateDbContextAsync();
        var all = await db.Menus
            .AsNoTracking()
            .Where(m => m.Active)
            .OrderBy(m => m.ShowOrder)
            .ToListAsync();

        bool CanView(Menu m)
        {
            if (m.IsDashboard || !m.RequiresPermission) return true;
            if (string.IsNullOrEmpty(m.PageName)) return false;
            return viewable is null
                || viewable.Contains(PermissionService.Normalise(m.PageName));
        }

        var childrenByParent = all
            .Where(m => m.ParentId != null)
            .ToLookup(m => m.ParentId!.Value);

        var roots = new List<MenuNode>();
        foreach (var top in all.Where(m => m.ParentId == null))
        {
            if (string.IsNullOrEmpty(top.PageName))
            {
                // Group header: include only the children the user may see.
                var node = new MenuNode { Menu = top };
                foreach (var child in childrenByParent[top.MenuId])
                    if (CanView(child))
                        node.Children.Add(new MenuNode { Menu = child });

                // Hide an empty group entirely.
                if (node.Children.Count > 0)
                    roots.Add(node);
            }
            else if (CanView(top))
            {
                // Standalone top-level leaf (Dashboard, Staff).
                roots.Add(new MenuNode { Menu = top });
            }
        }

        _roots = roots;
    }

    private RenderFragment RenderLink(Menu m) => builder =>
    {
        builder.OpenComponent<Microsoft.AspNetCore.Components.Routing.NavLink>(0);
        builder.AddAttribute(1, "class", "nav-link-dhl");
        builder.AddAttribute(2, "href", m.PageName ?? string.Empty);
        if (m.MatchAll)
            builder.AddAttribute(3, "Match", Microsoft.AspNetCore.Components.Routing.NavLinkMatch.All);
        builder.AddAttribute(4, "ChildContent", (RenderFragment)(inner =>
        {
            inner.OpenElement(5, "span");
            inner.AddAttribute(6, "class", "nav-icon");
            inner.AddContent(7, m.Icon);
            inner.CloseElement();
            inner.AddContent(8, $" {m.MenuName}");
        }));
        builder.CloseComponent();
    };
}
