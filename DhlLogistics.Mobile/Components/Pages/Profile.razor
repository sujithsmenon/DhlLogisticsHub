@page "/profile"
@inject AuthService Auth
@inject NavigationManager Nav

<div class="mob-page">

    @if (!Auth.IsLoggedIn)
    {
        <div style="text-align:center;padding:48px 0;">
            <button class="btn-dhl" @onclick='() => Nav.NavigateTo("/login")'>Sign In</button>
        </div>
        return;
    }

    <!-- Avatar + name -->
    <div class="profile-hero">
        <div class="profile-avatar">@Initials(Auth.CurrentFullName ?? "??")</div>
        <div class="profile-name">@Auth.CurrentFullName</div>
        <div class="profile-role">@Auth.CurrentRole</div>
    </div>

    <!-- Info card -->
    <div class="mob-card">
        @InfoRow("Role", Auth.CurrentRole ?? "—")
        @InfoRow("User ID", Auth.CurrentUserId ?? "—")
        @InfoRow("App Version", "1.0.0")
        @InfoRow("Server", AppConfig.ApiBaseUrl)
    </div>

    <!-- Role description -->
    <div class="mob-section-title">Permissions</div>
    <div class="mob-card" style="padding:14px 16px;">
        <p style="font-size:13px;color:#374151;line-height:1.6;margin:0;">
            @RoleDescription(Auth.CurrentRole ?? "")
        </p>
    </div>

    <!-- Logout -->
    <button class="logout-btn" @onclick="Logout">Sign Out</button>
</div>

<style>
.mob-page { padding: 16px; }

.mob-section-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; color: #9ca3af; margin: 16px 0 8px; }

.mob-card { background: #fff; border-radius: 14px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,.08); margin-bottom: 4px; }

.profile-hero {
    display: flex; flex-direction: column; align-items: center;
    padding: 32px 0 24px; text-align: center;
}
.profile-avatar {
    width: 72px; height: 72px; border-radius: 50%; background: #0868B2;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-weight: 800; font-size: 26px; margin-bottom: 12px;
    box-shadow: 0 4px 16px rgba(8,104,178,.3);
}
.profile-name { font-size: 20px; font-weight: 800; color: #111; }
.profile-role {
    font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .8px;
    color: #0868B2; margin-top: 4px;
}

.info-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 12px 16px; border-bottom: 1px solid #f3f4f6;
}
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 12px; color: #9ca3af; font-weight: 600; }
.info-value { font-size: 12px; color: #111; font-weight: 600; text-align: right; max-width: 60%; word-break: break-all; }

.logout-btn {
    width: 100%; margin-top: 24px; padding: 14px;
    background: #fee2e2; color: #b91c1c; border: none;
    border-radius: 14px; font-size: 15px; font-weight: 700; cursor: pointer;
}

.btn-dhl { background: #0868B2; color: #fff; border: none; padding: 12px 28px; border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer; }
</style>

@code {
    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login");
    }

    private static string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2 ? $"{parts[0][0]}{parts[^1][0]}" : name.Length > 0 ? name[0].ToString() : "?";
    }

    private static string RoleDescription(string role) => role switch
    {
        "Admin"     => "Full access to all system features — users, vehicles, jobs, cargo, and reports.",
        "Manager"   => "Can assign jobs to executives, monitor fleet, and view all operational data.",
        "Executive" => "Field agent — can update job status, send GPS location, and manage assigned pickups.",
        _           => "Read-only access to the dashboard.",
    };

    private RenderFragment InfoRow(string label, string value) =>
        @<div class="info-row">
            <span class="info-label">@label</span>
            <span class="info-value">@value</span>
        </div>;
}
