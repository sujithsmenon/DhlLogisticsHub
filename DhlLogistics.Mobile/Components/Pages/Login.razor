@page "/login"
@inject AuthService Auth
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Sign In — PVGT Logistics LLP</PageTitle>

<div class="auth-bg">

    <!-- ── Brand header (navy/blue gradient — matches web's left panel) ── -->
    <div class="auth-hero">
        <div class="auth-brand">
            <div class="auth-pvgt-mark">
                <img src="img/pvgt-logo.png" alt="PVGT Logistics" class="auth-pvgt-logo" />
            </div>
            <div class="auth-brand-words">
                <span class="auth-brand-name">PVGT Logistics LLP</span>
                <span class="auth-brand-sub">Your Trust &amp; Satisfaction</span>
            </div>
        </div>

        <h1 class="auth-hero-h1">Manage<br />logistics<br />smarter.</h1>
        <p class="auth-hero-p">
            Real-time GPS tracking, automated job parsing, and
            container oversight — all from one secure platform.
        </p>
    </div>

    <!-- ── Form card ────────────────────────────────────────────────── -->
    <div class="auth-card @(_shaking ? "auth-shake" : "")">

        <div class="auth-card-head">
            <div class="auth-card-mark">
                <img src="img/pvgt-logo.png" alt="PVGT Logistics" class="auth-card-logo" />
            </div>
            <h2 class="auth-card-title">Welcome back</h2>
            <p class="auth-card-sub">Sign in to your account to continue</p>
        </div>

        @if (_error is not null)
        {
            <div class="auth-alert" role="alert">
                <span class="auth-alert-icon">⚠</span> @_error
            </div>
        }

        <div class="auth-field">
            <label for="auth-email">Email address</label>
            <div class="auth-input-wrap @(_error != null ? "input-error" : "")">
                <span class="auth-icon">✉</span>
                <input id="auth-email"
                       type="email"
                       @bind="_email"
                       @bind:event="oninput"
                       placeholder="you@pvgtlogistics.com"
                       autocomplete="email" />
            </div>
        </div>

        <div class="auth-field">
            <label for="auth-pw">Password</label>
            <div class="auth-input-wrap @(_error != null ? "input-error" : "")">
                <span class="auth-icon">🔒</span>
                <input id="auth-pw"
                       type="@(_showPw ? "text" : "password")"
                       @bind="_password"
                       @bind:event="oninput"
                       placeholder="Enter your password"
                       autocomplete="current-password" />
                <button class="auth-eye-btn" type="button" @onclick="() => _showPw = !_showPw"
                        title="@(_showPw ? "Hide password" : "Show password")">
                    @(_showPw ? "🙈" : "👁")
                </button>
            </div>
        </div>

        <button class="auth-submit @(_busy ? "auth-loading" : "")"
                @onclick="DoLogin"
                disabled="@(_busy || string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))">
            @if (_busy)
            {
                <span class="auth-spinner"></span>
                <span>Signing in…</span>
            }
            else
            {
                <span>Sign In</span>
                <span class="auth-arrow">→</span>
            }
        </button>

        <div class="auth-help">
            <span>Need access?</span>
            <a href="mailto:admin@pvgtlogistics.com">Contact support</a>
        </div>
    </div>

    <p class="auth-copy">&copy; @DateTime.Now.Year PVGT Logistics LLP. Authorized use only.</p>
</div>

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
    height: 100%;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #F5F6FA;
}

.auth-bg {
    min-height: 100vh;
    background: #F5F6FA;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 0 28px;
}

/* ── Hero header (navy → blue gradient, matches web left panel) ── */
.auth-hero {
    width: 100%;
    background: linear-gradient(160deg, #0E2A47 0%, #0868B2 100%);
    padding: 40px 28px 56px;
    position: relative;
    overflow: hidden;
}

.auth-hero::before {
    content: '';
    position: absolute;
    top: -80px; right: -80px;
    width: 280px; height: 280px;
    background: radial-gradient(circle, rgba(8,104,178,.18) 0%, transparent 70%);
    pointer-events: none;
}
.auth-hero::after {
    content: '';
    position: absolute;
    bottom: -60px; left: -40px;
    width: 220px; height: 220px;
    background: radial-gradient(circle, rgba(8,104,178,.10) 0%, transparent 70%);
    pointer-events: none;
}

.auth-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    position: relative;
    z-index: 1;
}

.auth-pvgt-mark {
    background: #FFFFFF;
    border-radius: 8px;
    padding: 6px 10px;
    display: flex;
    align-items: center;
    justify-content: center;
}
.auth-pvgt-logo {
    display: block;
    height: 28px;
    width: auto;
    max-width: 100px;
}

.auth-brand-words { display: flex; flex-direction: column; }
.auth-brand-name {
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    line-height: 1.3;
}
.auth-brand-sub {
    color: rgba(255,255,255,.55);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: .5px;
}

.auth-hero-h1 {
    color: #fff;
    font-size: 34px;
    font-weight: 800;
    line-height: 1.12;
    letter-spacing: -.5px;
    margin-top: 32px;
    margin-bottom: 14px;
    position: relative;
    z-index: 1;
}

.auth-hero-p {
    color: rgba(255,255,255,.62);
    font-size: 13.5px;
    line-height: 1.65;
    max-width: 320px;
    position: relative;
    z-index: 1;
}

/* ── Form card ───────────────────────────────────────────────────── */
.auth-card {
    background: #fff;
    border-radius: 18px;
    box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 8px 32px rgba(0,0,0,.09);
    padding: 34px 26px 28px;
    width: calc(100% - 32px);
    max-width: 424px;
    margin-top: -28px;
    z-index: 2;
    position: relative;
}

.auth-card-head { margin-bottom: 26px; }

.auth-card-mark {
    display: flex;
    width: fit-content;
    margin-bottom: 18px;
}
.auth-card-logo {
    display: block;
    height: 32px;
    width: auto;
    max-width: 120px;
}

.auth-card-title {
    font-size: 24px;
    font-weight: 800;
    color: #111827;
    letter-spacing: -.3px;
    margin-bottom: 4px;
}
.auth-card-sub {
    color: #6B7280;
    font-size: 13px;
}

/* ── Alert ───────────────────────────────────────────────────────── */
.auth-alert {
    display: flex;
    align-items: center;
    gap: 9px;
    background: #FEF2F2;
    border: 1px solid #FECACA;
    color: #B91C1C;
    border-radius: 10px;
    padding: 11px 14px;
    font-size: 13px;
    margin-bottom: 20px;
}
.auth-alert-icon { font-size: 15px; flex-shrink: 0; }

/* ── Fields ──────────────────────────────────────────────────────── */
.auth-field {
    display: flex;
    flex-direction: column;
    gap: 7px;
    margin-bottom: 16px;
}

.auth-field label {
    font-size: 13px;
    font-weight: 600;
    color: #374151;
}

.auth-input-wrap {
    display: flex;
    align-items: center;
    border: 1.5px solid #E5E7EB;
    border-radius: 10px;
    background: #F9FAFB;
    transition: border-color .15s, box-shadow .15s, background .15s;
    overflow: hidden;
    min-height: 48px;
}

.auth-input-wrap:focus-within {
    border-color: #0868B2;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(8,104,178,.09);
}

.auth-input-wrap.input-error { border-color: #FCA5A5; background: #FFF5F5; }

.auth-icon {
    flex-shrink: 0;
    padding: 0 12px;
    font-size: 14px;
    color: #9CA3AF;
    user-select: none;
}

.auth-input-wrap input {
    flex: 1;
    border: none;
    background: transparent;
    outline: none;
    padding: 12px 14px 12px 0;
    font-size: 14px;
    color: #111827;
}
.auth-input-wrap input::placeholder { color: #9CA3AF; }

.auth-eye-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0 12px;
    font-size: 16px;
    color: #9CA3AF;
    flex-shrink: 0;
    line-height: 1;
}

/* ── Submit ──────────────────────────────────────────────────────── */
.auth-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 14px;
    background: #0868B2;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: .2px;
    transition: background .15s, transform .1s, box-shadow .15s, opacity .15s;
    margin-top: 6px;
    box-shadow: 0 4px 14px rgba(8,104,178,.3);
}
.auth-submit:hover:not(:disabled) {
    background: #055891;
    box-shadow: 0 6px 20px rgba(8,104,178,.4);
}
.auth-submit:active:not(:disabled) { transform: scale(.985); }
.auth-submit:disabled { opacity: .6; cursor: not-allowed; box-shadow: none; }

.auth-arrow { font-size: 17px; }

/* Loading spinner */
.auth-spinner {
    width: 18px;
    height: 18px;
    border: 2px solid rgba(255,255,255,.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin .7s linear infinite;
    flex-shrink: 0;
}
@@keyframes spin { to { transform: rotate(360deg); } }

/* ── Help / footer ───────────────────────────────────────────────── */
.auth-help {
    margin-top: 22px;
    text-align: center;
    font-size: 12.5px;
    color: #9CA3AF;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
}
.auth-help a {
    color: #0868B2;
    text-decoration: none;
    font-weight: 600;
}
.auth-help a:hover { text-decoration: underline; }

.auth-copy {
    margin-top: 22px;
    color: #B0B7C3;
    font-size: 11.5px;
    text-align: center;
}

/* Shake on error */
@@keyframes authShake {
    0%, 100% { transform: translateX(0); }
    20%       { transform: translateX(-6px); }
    40%       { transform: translateX(6px); }
    60%       { transform: translateX(-4px); }
    80%       { transform: translateX(4px); }
}
.auth-shake { animation: authShake .4s ease; }
</style>

@code {
    private string  _email    = string.Empty;
    private string  _password = string.Empty;
    private string? _error;
    private bool    _busy;
    private bool    _showPw;
    private bool    _shaking;

    protected override async Task OnInitializedAsync()
    {
        // Wake the Render free-tier container in the background while the user
        // types credentials. By the time they tap Sign In (5-10s of typing),
        // /api/auth/login will hit a warm server instead of a cold-start wait.
        _ = Api.WarmupAsync();

        if (await Auth.TryRestoreSessionAsync())
            Nav.NavigateTo("/");
    }

    private async Task DoLogin()
    {
        _error    = null;
        _busy     = true;
        _shaking  = false;

        var ok = await Auth.LoginAsync(_email, _password);

        _busy = false;

        if (ok)
        {
            Nav.NavigateTo("/");
        }
        else
        {
            _error   = "Invalid email or password. Please try again.";
            _shaking = true;
            StateHasChanged();
            await Task.Delay(500);
            _shaking = false;
        }
    }
}
