@page "/login"
@inject AuthService Auth
@inject NavigationManager Nav

<div class="mob-auth-bg">

    <!-- Top brand block -->
    <div class="mob-brand">
        <div class="mob-dhl-mark">
            <span class="mob-dhl-txt">DHL</span>
            <div class="mob-dhl-bar"></div>
        </div>
        <div class="mob-brand-words">
            <span class="mob-brand-name">Logistics Hub</span>
            <span class="mob-brand-sub">Field Executive App</span>
        </div>
    </div>

    <!-- Card -->
    <div class="mob-card @(_shaking ? "mob-shake" : "")">

        <div class="mob-card-head">
            <h2 class="mob-card-title">Sign in</h2>
            <p class="mob-card-sub">Use your DHL credentials to continue</p>
        </div>

        @if (_error is not null)
        {
            <div class="mob-alert" role="alert">
                <span>⚠</span> @_error
            </div>
        }

        <div class="mob-field">
            <label for="mob-email">Email address</label>
            <div class="mob-input-wrap @(_error != null ? "input-err" : "")">
                <span class="mob-icon">✉</span>
                <input id="mob-email"
                       type="email"
                       @bind="_email"
                       @bind:event="oninput"
                       placeholder="you@dhl.com"
                       autocomplete="email" />
            </div>
        </div>

        <div class="mob-field">
            <label for="mob-pw">Password</label>
            <div class="mob-input-wrap @(_error != null ? "input-err" : "")">
                <span class="mob-icon">🔒</span>
                <input id="mob-pw"
                       type="@(_showPw ? "text" : "password")"
                       @bind="_password"
                       @bind:event="oninput"
                       placeholder="Enter your password"
                       autocomplete="current-password" />
                <button class="mob-eye-btn" type="button" @onclick="() => _showPw = !_showPw"
                        title="@(_showPw ? "Hide password" : "Show password")">
                    @(_showPw ? "🙈" : "👁")
                </button>
            </div>
        </div>

        <button class="mob-submit @(_busy ? "mob-loading" : "")"
                @onclick="DoLogin"
                disabled="@(_busy || string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))">
            @if (_busy)
            {
                <span class="mob-spinner"></span>
                <span>Signing in…</span>
            }
            else
            {
                <span>Sign In</span>
                <span class="mob-arrow">→</span>
            }
        </button>

        <p class="mob-hint">Authorized DHL personnel only</p>
    </div>

    <p class="mob-footer">&copy; @DateTime.Now.Year DHL Logistics Hub</p>
</div>

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body, html {
    height: 100%;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #1C1C1E;
}

.mob-auth-bg {
    min-height: 100vh;
    background: linear-gradient(160deg, #1C1C1E 0%, #2A1010 60%, #1C1C1E 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 48px 20px 32px;
}

/* ── Brand ──────────────────────────────────────────── */
.mob-brand {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 36px;
}

.mob-dhl-mark { display: flex; flex-direction: column; }
.mob-dhl-txt {
    background: #D40511;
    color: #fff;
    font-weight: 900;
    font-size: 18px;
    padding: 7px 12px;
    border-radius: 7px 7px 0 0;
    letter-spacing: 2px;
    line-height: 1;
}
.mob-dhl-bar {
    height: 5px;
    background: #FFCC00;
    border-radius: 0 0 5px 5px;
}

.mob-brand-words { display: flex; flex-direction: column; }
.mob-brand-name {
    color: #fff;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.2;
}
.mob-brand-sub {
    color: rgba(255,255,255,.38);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .5px;
}

/* ── Card ───────────────────────────────────────────── */
.mob-card {
    background: #fff;
    border-radius: 20px;
    padding: 32px 28px 28px;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 20px 60px rgba(0,0,0,.5);
}

.mob-card-head { margin-bottom: 24px; }
.mob-card-title {
    font-size: 22px;
    font-weight: 800;
    color: #111827;
    margin-bottom: 4px;
}
.mob-card-sub { font-size: 13px; color: #6B7280; }

/* Alert */
.mob-alert {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #FEF2F2;
    border: 1px solid #FECACA;
    color: #B91C1C;
    border-radius: 10px;
    padding: 11px 14px;
    font-size: 13px;
    margin-bottom: 18px;
}

/* Fields */
.mob-field {
    display: flex;
    flex-direction: column;
    gap: 7px;
    margin-bottom: 16px;
}

.mob-field label {
    font-size: 13px;
    font-weight: 600;
    color: #374151;
}

.mob-input-wrap {
    display: flex;
    align-items: center;
    border: 1.5px solid #E5E7EB;
    border-radius: 12px;
    background: #F9FAFB;
    transition: border-color .15s, box-shadow .15s, background .15s;
    overflow: hidden;
    min-height: 50px;
}

.mob-input-wrap:focus-within {
    border-color: #D40511;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(212,5,17,.1);
}

.mob-input-wrap.input-err { border-color: #FCA5A5; background: #FFF5F5; }

.mob-icon {
    flex-shrink: 0;
    padding: 0 14px;
    font-size: 16px;
    color: #9CA3AF;
    user-select: none;
}

.mob-input-wrap input {
    flex: 1;
    border: none;
    background: transparent;
    outline: none;
    padding: 14px 0;
    font-size: 15px;
    color: #111827;
}
.mob-input-wrap input::placeholder { color: #9CA3AF; }

.mob-eye-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0 14px;
    font-size: 18px;
    color: #9CA3AF;
    flex-shrink: 0;
    line-height: 1;
}

/* Submit */
.mob-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 15px;
    background: #D40511;
    color: #fff;
    border: none;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: .2px;
    transition: background .15s, opacity .15s, transform .1s;
    box-shadow: 0 4px 18px rgba(212,5,17,.35);
    margin-top: 8px;
}

.mob-submit:hover:not(:disabled) { background: #A8040D; }
.mob-submit:active:not(:disabled) { transform: scale(.98); }
.mob-submit:disabled { opacity: .6; cursor: not-allowed; box-shadow: none; }

.mob-arrow { font-size: 18px; }

/* Loading spinner */
.mob-spinner {
    width: 18px;
    height: 18px;
    border: 2px solid rgba(255,255,255,.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin .7s linear infinite;
    flex-shrink: 0;
}

@@keyframes spin { to { transform: rotate(360deg); } }

.mob-hint {
    text-align: center;
    font-size: 11.5px;
    color: #9CA3AF;
    margin-top: 16px;
}

/* Shake animation */
@@keyframes mobShake {
    0%, 100% { transform: translateX(0); }
    15%       { transform: translateX(-8px); }
    35%       { transform: translateX(8px); }
    55%       { transform: translateX(-5px); }
    75%       { transform: translateX(5px); }
}
.mob-shake { animation: mobShake .45s ease; }

/* Footer */
.mob-footer {
    color: rgba(255,255,255,.25);
    font-size: 11px;
    text-align: center;
    margin-top: 28px;
}
</style>

@code {
    private string  _email    = string.Empty;
    private string  _password = string.Empty;
    private string? _error;
    private bool    _busy;
    private bool    _showPw;
    private bool    _shaking;

    protected override async Task OnInitializedAsync()
    {
        if (await Auth.TryRestoreSessionAsync())
            Nav.NavigateTo("/");
    }

    private async Task DoLogin()
    {
        _error    = null;
        _busy     = true;
        _shaking  = false;

        var ok = await Auth.LoginAsync(_email, _password);

        _busy = false;

        if (ok)
        {
            Nav.NavigateTo("/");
        }
        else
        {
            _error   = "Invalid email or password. Please try again.";
            _shaking = true;
            StateHasChanged();
            await Task.Delay(500);
            _shaking = false;
        }
    }
}
